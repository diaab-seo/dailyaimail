---
export const prerender = false;

import { getCollection, render } from "astro:content";
import { env } from "cloudflare:workers";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getSession } from "../../lib/auth";
import { getApprovedComments } from "../../lib/db";
import type { DBComment } from "../../lib/db";
import type { SessionUser } from "../../lib/auth";

const db = (env as any).DB as D1Database | undefined;
const kv = (env as any).SESSION as KVNamespace | undefined;

const { slug } = Astro.params;
const entries = await getCollection("articles");
const entry = entries.find((e) => e.id === slug);

if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);

let user: SessionUser | null = null;
let comments: DBComment[] = [];

if (db && kv) {
  [user, comments] = await Promise.all([
    getSession(kv, Astro.cookies),
    getApprovedComments(db, slug!),
  ]);
}

const article = {
  slug: entry.id,
  tag: entry.data.tag,
  tags: [...new Set([entry.data.tag, ...(entry.data.tags ?? [])])],
  headline: entry.data.headline,
  excerpt: entry.data.excerpt,
  body: entry.body ?? "",
  date: entry.data.date,
  isoDate: entry.data.isoDate,
  modifiedDate: entry.data.modifiedDate ?? entry.data.isoDate,
  author: entry.data.author,
  authorUrl: entry.data.authorUrl ?? "https://interactiveseo.digital",
  readingTime: entry.data.readingTime,
  image: entry.data.image,
  imageWidth: entry.data.imageWidth,
  imageHeight: entry.data.imageHeight,
  imageCaption: entry.data.imageCaption,
  keywords: entry.data.keywords ?? [entry.data.tag],
  articleSection: entry.data.articleSection ?? [entry.data.tag],
};
---

<ArticleLayout article={article} comments={comments} user={user}>
  <Content />
</ArticleLayout>
