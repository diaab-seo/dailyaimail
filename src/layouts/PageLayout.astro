---
import Layout from "./Layout.astro";

const fm = (Astro.props as any).frontmatter ?? {};

const title = Astro.props.title ?? fm.title;
const description = Astro.props.description ?? fm.description;
const metaTitle = Astro.props.metaTitle ?? fm.metaTitle;
const publishDate = Astro.props.publishDate ?? fm.publishDate;
const lastModified = Astro.props.lastModified ?? fm.lastModified;
const author = Astro.props.author ?? fm.author;
const schemaType = Astro.props.schemaType ?? fm.schemaType ?? null;

// ── Schema generation ─────────────────────────────────────────────────────────
const siteUrl = "https://dailyaimail.com";
const logoUrl = `${siteUrl}/logo.png`;

// Helper — only generate schema blocks for specific page types
// Currently handles "about" — expand with "contact", "press-kit" etc. as needed
let pageSchema: object | null = null;

if (schemaType === "about") {
  const pubIso = publishDate?.replace(/\//g, "-") ?? "2026-01-01";
  const modIso = lastModified?.replace(/\//g, "-") ?? "2026-03-15";

  pageSchema = {
    "@context": "https://schema.org",
    "@graph": [
      // 1. AboutPage — the page itself, with mainEntity pointing to the Organization
      // mainEntity is the strongest "this page IS about this thing" signal in Schema.org
      {
        "@type": "AboutPage",
        "@id": `${siteUrl}/about-us`,
        url: `${siteUrl}/about-us`,
        name: "About Daily AI Mail — Independent AI News, Research & Intelligence",
        headline: "About Daily AI Mail",
        description:
          "Daily AI Mail is an independent digital publication covering artificial intelligence news, research breakthroughs, tool releases, and policy developments for a global audience.",
        inLanguage: "en-US",
        isPartOf: { "@id": `${siteUrl}/#website` },
        // mainEntity — the single strongest signal: this page IS the org's about page
        mainEntity: { "@id": `${siteUrl}/#organization` },
        // about — secondary entity reference
        about: { "@id": `${siteUrl}/#organization` },
        author: { "@id": `${siteUrl}/#/schema/person/mohamed-diab` },
        creator: { "@id": `${siteUrl}/#/schema/person/mohamed-diab` },
        publisher: { "@id": `${siteUrl}/#organization` },
        datePublished: `${pubIso}T00:00:00+00:00`,
        dateModified: `${modIso}T00:00:00+00:00`,
        image: { "@id": `${siteUrl}/#/schema/logo/image/` },
        breadcrumb: { "@id": `${siteUrl}/about-us#breadcrumb` },
        isAccessibleForFree: true,
        license: `${siteUrl}/terms-and-conditions`,
        speakable: {
          "@type": "SpeakableSpecification",
          cssSelector: [".page-title", ".page-content p:first-of-type"],
        },
        // relatedLinks — internal mesh to key editorial pages
        relatedLink: [
          `${siteUrl}/publishing-principles`,
          `${siteUrl}/contact-us`,
          `${siteUrl}/privacy-policy`,
        ],
        mentions: [
          { "@id": `${siteUrl}/#/schema/person/mohamed-diab` },
          { "@id": `${siteUrl}/#organization` },
        ],
      },

      // 2. BreadcrumbList
      {
        "@type": "BreadcrumbList",
        "@id": `${siteUrl}/about-us#breadcrumb`,
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: `${siteUrl}/`,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: "About Us",
            item: `${siteUrl}/about-us`,
          },
        ],
      },

      // 3. NewsMediaOrganization — FULL definition
      // This is one of two pages (with Homepage) where the org is fully defined.
      // The About page is the most semantically appropriate place to declare it.
      {
        "@type": "NewsMediaOrganization",
        "@id": `${siteUrl}/#organization`,
        name: "Daily AI Mail",
        alternateName: "DailyAIMail",
        url: `${siteUrl}/`,
        foundingDate: "2026-01-01",
        description:
          "Daily AI Mail is an independent digital publication dedicated to covering the global artificial intelligence industry for researchers, engineers, business leaders, and policymakers.",
        publishingPrinciples: `${siteUrl}/publishing-principles`,
        ethicsPolicy: `${siteUrl}/publishing-principles`,
        masthead: `${siteUrl}/about-us`,
        diversityPolicy: `${siteUrl}/publishing-principles`,
        missionCoveragePrioritiesPolicy: `${siteUrl}/publishing-principles`,
        correctionsPolicy: `${siteUrl}/publishing-principles`,
        logo: {
          "@type": "ImageObject",
          "@id": `${siteUrl}/#/schema/logo/image/`,
          inLanguage: "en-US",
          url: logoUrl,
          contentUrl: logoUrl,
          width: 512,
          height: 512,
          caption: "Daily AI Mail",
        },
        image: { "@id": `${siteUrl}/#/schema/logo/image/` },
        contactPoint: [
          {
            "@type": "ContactPoint",
            email: "editorial@dailyaimail.com",
            contactType: "editorial",
            availableLanguage: ["English"],
          },
          {
            "@type": "ContactPoint",
            email: "press@dailyaimail.com",
            contactType: "press",
            availableLanguage: ["English"],
          },
          {
            "@type": "ContactPoint",
            email: "corrections@dailyaimail.com",
            contactType: "corrections",
            availableLanguage: ["English"],
          },
        ],
        member: { "@id": `${siteUrl}/#/schema/person/mohamed-diab` },
        founder: { "@id": `${siteUrl}/#/schema/person/mohamed-diab` },
        areaServed: [
          { "@type": "Place", name: "Worldwide" },
          { "@type": "Country", name: "Egypt" },
          { "@type": "Place", name: "MENA" },
        ],
        knowsAbout: [
          "Artificial Intelligence",
          "Machine Learning",
          "Large Language Models",
          "AI Safety",
          "Generative AI",
          "AI Policy",
          "AI Ethics",
          "Neural Networks",
          "Natural Language Processing",
          "AI Research",
        ],
        // subjectOf — the about page IS the subject document for this org
        subjectOf: { "@id": `${siteUrl}/about-us` },
        sameAs: [
          "https://twitter.com/dailyaimail",
          "https://linkedin.com/company/dailyaimail",
          "https://diab.digital",
        ],
      },

      // 4. Person — Mohamed Diab — FULL definition
      // Deeper bio-level properties live here since this is a human-authored about page
      {
        "@type": "Person",
        "@id": `${siteUrl}/#/schema/person/mohamed-diab`,
        name: "Mohamed Diab",
        givenName: "Mohamed",
        familyName: "Diab",
        url: "https://interactiveseo.digital",
        image: {
          "@type": "ImageObject",
          url: `${siteUrl}/images/mohamed-diab.jpg`,
          caption: "Mohamed Diab",
        },
        jobTitle: "Founder & Editor-in-Chief",
        description:
          "Technical SEO Consultant and founder of Daily AI Mail, with over ten years of experience in the technology and digital marketing industry. Specialises in entity-based SEO, structured data strategy, and Knowledge Graph optimization.",
        worksFor: { "@id": `${siteUrl}/#organization` },
        alumniOf: [],
        hasCredential: {
          "@type": "EducationalOccupationalCredential",
          name: "Ten years of technical SEO practice",
          credentialCategory: "professional experience",
        },
        knowsAbout: [
          "Technical SEO",
          "Structured Data",
          "Schema.org",
          "Knowledge Graph Optimization",
          "Artificial Intelligence",
          "AI News",
          "Digital Publishing",
          "Entity-Based SEO",
          "Google News",
          "Google Discover",
        ],
        // homeLocation — city-level, not personal address
        homeLocation: {
          "@type": "Place",
          name: "Egypt",
        },
        sameAs: ["https://interactiveseo.digital", "https://diab.digital"],
      },

      // 5. WebSite — referenced (fully defined on homepage)
      {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        url: `${siteUrl}/`,
        name: "Daily AI Mail",
        description: "Your daily source for AI news, research and tools.",
        publisher: { "@id": `${siteUrl}/#organization` },
        inLanguage: "en-US",
      },
    ],
  };
}
---

<Layout title={title} description={description} metaTitle={metaTitle}>
  {
    pageSchema && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(pageSchema)}
        slot="head"
      />
    )
  }

  <main class="page-main">
    <div class="page-container">
      <header class="page-header">
        <h1 class="page-title">{title}</h1>
        <div class="page-meta">
          {author && <span>By {author}</span>}
          {publishDate && <span>Published {publishDate}</span>}
          {lastModified && <span>Last updated {lastModified}</span>}
        </div>
      </header>
      <div class="page-content">
        <slot />
      </div>
    </div>
  </main>
</Layout>

<style>
  .page-main {
    min-height: 100vh;
    padding: 80px var(--gutter) var(--gutter);
  }
  .page-container {
    max-width: 720px;
    margin: 0 auto;
  }
  .page-header {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 40px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .page-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .page-content {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-muted);
  }
  .page-content h2 {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--color-text);
    margin: 40px 0 16px;
  }
  .page-content h3 {
    font-family: var(--font-display);
    font-size: 19px;
    color: var(--color-text);
    margin: 28px 0 12px;
  }
  .page-content p {
    margin-bottom: 16px;
  }
  .page-content a {
    text-decoration: underline;
  }
  .page-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 14px;
  }
  .page-content th {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
  }
  .page-content td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
  }
  .page-content ul,
  .page-content ol {
    margin: 0 0 16px 24px;
  }
  .page-content li {
    margin-bottom: 6px;
  }
  .page-content strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .page-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }
</style>
