---
import Layout from "./Layout.astro";

// When a .md file uses this layout, Astro passes all frontmatter under
// Astro.props.frontmatter — NOT as top-level props. We merge both sources
// so this layout works whether called from .astro or .md files.
const fm = (Astro.props as any).frontmatter ?? {};

const title = Astro.props.title ?? fm.title;
const description = Astro.props.description ?? fm.description;
const metaTitle = Astro.props.metaTitle ?? fm.metaTitle;
const publishDate = Astro.props.publishDate ?? fm.publishDate;
const lastModified = Astro.props.lastModified ?? fm.lastModified;
const author = Astro.props.author ?? fm.author;
---

<Layout title={title} description={description} metaTitle={metaTitle}>
  <main class="page-main">
    <div class="page-container">
      <header class="page-header">
        <h1 class="page-title">{title}</h1>
        <div class="page-meta">
          {author && <span>By {author}</span>}
          {publishDate && <span>Published {publishDate}</span>}
          {lastModified && <span>Last updated {lastModified}</span>}
        </div>
      </header>
      <div class="page-content">
        <slot />
      </div>
    </div>
  </main>
</Layout>

<style>
  .page-main {
    min-height: 100vh;
    padding: 80px var(--gutter) var(--gutter);
  }
  .page-container {
    max-width: 720px;
    margin: 0 auto;
  }
  .page-header {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 40px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .page-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .page-content {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-muted);
  }
  .page-content h2 {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--color-text);
    margin: 40px 0 16px;
  }
  .page-content h3 {
    font-family: var(--font-display);
    font-size: 19px;
    color: var(--color-text);
    margin: 28px 0 12px;
  }
  .page-content p {
    margin-bottom: 16px;
  }
  .page-content a {
    text-decoration: underline;
  }
  .page-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 14px;
  }
  .page-content th {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
  }
  .page-content td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
  }
  .page-content ul,
  .page-content ol {
    margin: 0 0 16px 24px;
  }
  .page-content li {
    margin-bottom: 6px;
  }
  .page-content strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .page-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }
</style>
