---
import Layout from "./Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { resolvePageSchema } from "../utils/schema";

const fm = (Astro.props as any).frontmatter ?? {};

const title = Astro.props.title ?? fm.title;
const description = Astro.props.description ?? fm.description;
const metaTitle = Astro.props.metaTitle ?? fm.metaTitle;
const publishDate = Astro.props.publishDate ?? fm.publishDate;
const lastModified = Astro.props.lastModified ?? fm.lastModified;
const author = Astro.props.author ?? fm.author;
const schemaType = Astro.props.schemaType ?? fm.schemaType ?? null;

const SITE_URL = "https://dailyaimail.com";
const pubIso = (publishDate ?? "2026-01-01").replace(/\//g, "-");
const modIso = (lastModified ?? "2026-03-15").replace(/\//g, "-");
const logoUrl = `${SITE_URL}/logo.png`;

// ── Breadcrumb items (derived from schemaType) ────────────────────────────────
const breadcrumbMap: Record<string, { label: string; href: string }> = {
  about: { label: "About Us", href: "/about-us" },
  contact: { label: "Contact Us", href: "/contact-us" },
  "publishing-principles": {
    label: "Publishing Principles",
    href: "/publishing-principles",
  },
  privacy: { label: "Privacy Policy", href: "/privacy-policy" },
  cookies: { label: "Cookies Policy", href: "/cookies-policy" },
  terms: { label: "Terms & Conditions", href: "/terms-and-conditions" },
};
const crumb = breadcrumbMap[schemaType ?? ""];

// ── About schema (stays inline — too deep to genericize) ──────────────────────
let pageSchema: object | null = null;

if (schemaType === "about") {
  pageSchema = {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "AboutPage",
        "@id": `${SITE_URL}/about-us`,
        url: `${SITE_URL}/about-us`,
        name: metaTitle ?? "About Daily AI Mail",
        description:
          description ??
          "Daily AI Mail is an independent publication covering artificial intelligence news.",
        inLanguage: "en-US",
        isPartOf: { "@id": `${SITE_URL}/#website` },
        mainEntity: { "@id": `${SITE_URL}/#organization` },
        about: { "@id": `${SITE_URL}/#organization` },
        author: { "@id": `${SITE_URL}/#/schema/person/mohamed-diab` },
        publisher: { "@id": `${SITE_URL}/#organization` },
        datePublished: `${pubIso}T00:00:00+00:00`,
        dateModified: `${modIso}T00:00:00+00:00`,
        breadcrumb: { "@id": `${SITE_URL}/about-us#breadcrumb` },
        isAccessibleForFree: true,
        speakable: {
          "@type": "SpeakableSpecification",
          cssSelector: [".page-title"],
        },
        relatedLink: [
          `${SITE_URL}/publishing-principles`,
          `${SITE_URL}/contact-us`,
        ],
        mentions: [
          { "@id": `${SITE_URL}/#/schema/person/mohamed-diab` },
          { "@id": `${SITE_URL}/#organization` },
        ],
      },
      {
        "@type": "BreadcrumbList",
        "@id": `${SITE_URL}/about-us#breadcrumb`,
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: `${SITE_URL}/`,
          },
          {
            "@type": "ListItem",
            position: 2,
            name: "About Us",
            item: `${SITE_URL}/about-us`,
          },
        ],
      },
      {
        "@type": "NewsMediaOrganization",
        "@id": `${SITE_URL}/#organization`,
        name: "Daily AI Mail",
        url: `${SITE_URL}/`,
        foundingDate: "2026-01-01",
        description:
          "Daily AI Mail is an independent digital publication covering the global artificial intelligence industry.",
        publishingPrinciples: `${SITE_URL}/publishing-principles`,
        ethicsPolicy: `${SITE_URL}/publishing-principles`,
        masthead: `${SITE_URL}/about-us`,
        correctionsPolicy: `${SITE_URL}/publishing-principles`,
        missionCoveragePrioritiesPolicy: `${SITE_URL}/publishing-principles`,
        logo: {
          "@type": "ImageObject",
          "@id": `${SITE_URL}/#/schema/logo/image/`,
          url: logoUrl,
          contentUrl: logoUrl,
          width: 512,
          height: 512,
          caption: "Daily AI Mail",
        },
        image: { "@id": `${SITE_URL}/#/schema/logo/image/` },
        member: { "@id": `${SITE_URL}/#/schema/person/mohamed-diab` },
        founder: { "@id": `${SITE_URL}/#/schema/person/mohamed-diab` },
        subjectOf: { "@id": `${SITE_URL}/about-us` },
        contactPoint: [
          {
            "@type": "ContactPoint",
            email: "editorial@dailyaimail.com",
            contactType: "editorial",
          },
          {
            "@type": "ContactPoint",
            email: "press@dailyaimail.com",
            contactType: "press",
          },
          {
            "@type": "ContactPoint",
            email: "corrections@dailyaimail.com",
            contactType: "corrections",
          },
        ],
        knowsAbout: [
          "Artificial Intelligence",
          "Machine Learning",
          "Large Language Models",
          "AI Safety",
          "Generative AI",
          "AI Policy",
        ],
        sameAs: [
          "https://twitter.com/dailyaimail",
          "https://linkedin.com/company/dailyaimail",
          "https://diab.digital",
        ],
      },
      {
        "@type": "Person",
        "@id": `${SITE_URL}/#/schema/person/mohamed-diab`,
        name: "Mohamed Diab",
        givenName: "Mohamed",
        familyName: "Diab",
        url: "https://interactiveseo.digital",
        jobTitle: "Founder & Editor-in-Chief",
        description: "Technical SEO Consultant and founder of Daily AI Mail.",
        worksFor: { "@id": `${SITE_URL}/#organization` },
        knowsAbout: [
          "Technical SEO",
          "Structured Data",
          "Knowledge Graph Optimization",
          "Artificial Intelligence",
          "Digital Publishing",
        ],
        homeLocation: { "@type": "Place", name: "Egypt" },
        sameAs: ["https://interactiveseo.digital", "https://diab.digital"],
      },
      {
        "@type": "WebSite",
        "@id": `${SITE_URL}/#website`,
        url: `${SITE_URL}/`,
        name: "Daily AI Mail",
        publisher: { "@id": `${SITE_URL}/#organization` },
      },
    ],
  };
} else {
  pageSchema = resolvePageSchema(schemaType, {
    title: title ?? "",
    description: description ?? "",
    publishDate: pubIso,
    lastModified: modIso,
    metaTitle,
  });
}
---

<Layout
  title={title}
  description={description}
  metaTitle={metaTitle}
  canonical={`${SITE_URL}${crumb?.href ?? ""}`}
  ogTitle={metaTitle ?? title}
  ogDescription={description}
>
  {
    pageSchema && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(pageSchema)}
        slot="head"
      />
    )
  }

  {
    crumb && (
      <Breadcrumb
        items={[{ label: "Home", href: "/" }, { label: crumb.label }]}
      />
    )
  }

  <main class="page-main">
    <div class="page-container">
      <header class="page-header">
        <h1 class="page-title">{title}</h1>
        <div class="page-meta">
          {author && <span>By {author}</span>}
          {publishDate && <span>Published {publishDate}</span>}
          {lastModified && <span>Last updated {lastModified}</span>}
        </div>
      </header>
      <div class="page-content">
        <slot />
      </div>
    </div>
  </main>
</Layout>

<style>
  .page-main {
    min-height: 100vh;
    padding: 80px var(--gutter) var(--gutter);
  }
  .page-container {
    max-width: 720px;
    margin: 0 auto;
  }
  .page-header {
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 40px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .page-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .page-content {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text-muted);
  }
  .page-content h2 {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--color-text);
    margin: 40px 0 16px;
  }
  .page-content h3 {
    font-family: var(--font-display);
    font-size: 19px;
    color: var(--color-text);
    margin: 28px 0 12px;
  }
  .page-content p {
    margin-bottom: 16px;
  }
  .page-content a {
    text-decoration: underline;
  }
  .page-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 14px;
  }
  .page-content th {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
    font-weight: 600;
  }
  .page-content td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border);
  }
  .page-content ul,
  .page-content ol {
    margin: 0 0 16px 24px;
  }
  .page-content li {
    margin-bottom: 6px;
  }
  .page-content strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .page-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }
</style>
