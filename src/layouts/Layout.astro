---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  metaTitle?: string;
}

const directProps = Astro.props as Props;
const frontmatter = (Astro.props as any).frontmatter ?? {};

const title = directProps.title ?? frontmatter.title;
const description = directProps.description ?? frontmatter.description;
const metaTitle = directProps.metaTitle ?? frontmatter.metaTitle;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={description ??
        "Your daily source for AI news, research and tools."}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:opsz,wght@9..40,300;400;500;600&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>
      {metaTitle ?? (title ? `${title} — Daily AI Mail` : "Daily AI Mail")}
    </title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Per-page injections (JSON-LD, OG overrides, etc.) -->
    <slot name="head" />

    <!-- ⚡ Theme init — runs synchronously before paint -->
    <script is:inline>
      (function () {
        var pref = localStorage.getItem("dai-theme") || "system";
        var resolved =
          pref === "system"
            ? window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light"
            : pref;
        document.documentElement.setAttribute("data-theme", resolved);
        document.documentElement.setAttribute("data-theme-pref", pref);
      })();
    </script>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />

    <!-- ── Go To Top button (site-wide) ───────────────────── -->
    <button
      id="go-top-btn"
      class="go-top-btn"
      aria-label="Back to top"
      title="Back to top"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>
  </body>
</html>

<script is:inline>
  window.addEventListener("DOMContentLoaded", function () {
    document.documentElement.classList.add("theme-ready");
  });

  // Go To Top logic
  (function () {
    var btn = document.getElementById("go-top-btn");
    if (!btn) return;
    var SHOW_AT = 400; // px scrolled before button appears

    function onScroll() {
      if (window.scrollY > SHOW_AT) {
        btn.classList.add("visible");
      } else {
        btn.classList.remove("visible");
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });

    btn.addEventListener("click", function () {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  })();
</script>

<style is:global>
  /* ─── DARK THEME ──────────────────────────────────────── */
  :root,
  [data-theme="dark"] {
    color-scheme: dark;
    --color-bg: #080d1a;
    --color-surface: #0f1829;
    --color-border: rgba(232, 184, 75, 0.18);
    --color-text: #f4f0e8;
    --color-text-muted: #8a95a8;
    --color-accent: #e8b84b;
    --color-highlight: #3dd6c0;
    --card-bg: #111828;
    --gold: #e8b84b;
    --gold-light: #f5d07a;
    --teal: #3dd6c0;
    --nav-bg: #080d1a;
    --nav-text: #f4f0e8;
    --shadow-card:
      0 1px 3px rgba(0, 0, 0, 0.28), 0 4px 16px rgba(0, 0, 0, 0.22);
    --shadow-card-hover:
      0 4px 12px rgba(0, 0, 0, 0.4), 0 12px 32px rgba(0, 0, 0, 0.32);
  }

  /* ─── LIGHT THEME ─────────────────────────────────────── */
  [data-theme="light"] {
    color-scheme: light;
    --color-bg: #f4f0e8;
    --color-surface: #ffffff;
    --color-border: rgba(15, 24, 41, 0.13);
    --color-text: #0f1829;
    --color-text-muted: #4a5568;
    --color-accent: #8a6200;
    --color-highlight: #0a7a6e;
    --card-bg: #ede8df;
    --gold: #8a6200;
    --gold-light: #a07820;
    --teal: #0a7a6e;
    --nav-bg: #0f1829;
    --nav-text: #f4f0e8;
    --shadow-card:
      0 1px 3px rgba(15, 24, 41, 0.08), 0 4px 16px rgba(15, 24, 41, 0.06);
    --shadow-card-hover:
      0 4px 12px rgba(15, 24, 41, 0.14), 0 12px 32px rgba(15, 24, 41, 0.1);
  }

  /* ─── THEME-INDEPENDENT TOKENS ───────────────────────── */
  :root {
    --tag-anthropic: #7c3aed;
    --tag-google: #1967d2;
    --tag-openai: #10a37f;
    --tag-meta: #0082fb;
    --tag-tools: #d97706;
    --tag-policy: #dc2626;
    --tag-default: #4b5563;
    --font-display: "Playfair Display", serif;
    --font-body: "DM Sans", sans-serif;
    --font-mono: "DM Mono", monospace;
    --radius-card: 4px;
    --max-width: 1280px;
    --gutter: clamp(16px, 4vw, 48px);
  }

  /* ─── RESET ───────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  html.theme-ready body,
  html.theme-ready body *:not(svg):not(path) {
    transition:
      background-color 0.25s ease,
      color 0.2s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  body {
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
    -webkit-font-smoothing: antialiased;
  }
  img {
    display: block;
    max-width: 100%;
    height: auto;
  }
  a {
    color: inherit;
    text-decoration: none;
  }
  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ─── GO TO TOP BUTTON ────────────────────────────────── */
  .go-top-btn {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 900;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gold);
    color: #080d1a;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      background 0.15s;
  }
  .go-top-btn.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .go-top-btn:hover {
    background: var(--gold-light);
  }
  @media (max-width: 600px) {
    .go-top-btn {
      bottom: 18px;
      right: 18px;
      width: 40px;
      height: 40px;
    }
  }
</style>
