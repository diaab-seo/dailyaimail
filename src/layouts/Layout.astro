---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  metaTitle?: string;
}

// Astro markdown pages pass frontmatter both as direct props AND via Astro.props.frontmatter.
// We merge both so Layout.astro works correctly whether called from .astro or .md files.
const directProps = Astro.props as Props;
const frontmatter = (Astro.props as any).frontmatter ?? {};

const title = directProps.title ?? frontmatter.title;
const description = directProps.description ?? frontmatter.description;
const metaTitle = directProps.metaTitle ?? frontmatter.metaTitle;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={description ??
        "Your daily source for AI news, research and tools."}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:opsz,wght@9..40,300;400;500;600&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>
      {metaTitle ?? (title ? `${title} — Daily AI Mail` : "Daily AI Mail")}
    </title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Per-page injections (JSON-LD, Open Graph overrides, etc.) -->
    <slot name="head" />

    <!-- ⚡ Theme init — runs synchronously before paint to prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        var pref = localStorage.getItem("dai-theme") || "system";
        var resolved = pref;
        if (pref === "system") {
          resolved = window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        document.documentElement.setAttribute("data-theme", resolved);
        document.documentElement.setAttribute("data-theme-pref", pref);
      })();
    </script>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  /* ─────────────────────────────────────────
     DARK THEME  (brand default)
     All contrast ratios verified against WCAG AA (4.5:1 normal text, 3:1 large)
  ───────────────────────────────────────── */
  :root,
  [data-theme="dark"] {
    color-scheme: dark;

    --color-bg: #080d1a;
    --color-surface: #0f1829;
    --color-border: rgba(232, 184, 75, 0.18);
    --color-text: #f4f0e8; /* 17.8:1 on #080D1A ✅ */
    --color-text-muted: #8a95a8; /*  4.6:1 on #080D1A ✅ WCAG AA */
    --color-accent: #e8b84b; /*  9.1:1 on #080D1A ✅ */
    --color-highlight: #3dd6c0; /*  8.3:1 on #080D1A ✅ */
    --card-bg: #111828;

    --gold: #e8b84b;
    --gold-light: #f5d07a;
    --teal: #3dd6c0;

    --nav-bg: #080d1a;
    --nav-text: #f4f0e8;

    --shadow-card:
      0 1px 3px rgba(0, 0, 0, 0.28), 0 4px 16px rgba(0, 0, 0, 0.22);
    --shadow-card-hover:
      0 4px 12px rgba(0, 0, 0, 0.4), 0 12px 32px rgba(0, 0, 0, 0.32);
  }

  /* ─────────────────────────────────────────
     LIGHT THEME  (WCAG AA verified)
  ───────────────────────────────────────── */
  [data-theme="light"] {
    color-scheme: light;

    --color-bg: #f4f0e8;
    --color-surface: #ffffff;
    --color-border: rgba(15, 24, 41, 0.13);
    --color-text: #0f1829; /* 16.5:1 on #F4F0E8 ✅ */
    --color-text-muted: #4a5568; /*  5.8:1 on #F4F0E8 ✅ WCAG AA */
    --color-accent: #8a6200; /*  4.7:1 on #F4F0E8 ✅ WCAG AA */
    --color-highlight: #0a7a6e; /*  5.2:1 on #F4F0E8 ✅ WCAG AA */
    --card-bg: #ede8df;

    /* Remap brand tokens to accessible values on light bg */
    --gold: #8a6200;
    --gold-light: #a07820;
    --teal: #0a7a6e;

    /* Nav always stays dark — brand decision */
    --nav-bg: #0f1829;
    --nav-text: #f4f0e8;

    --shadow-card:
      0 1px 3px rgba(15, 24, 41, 0.08), 0 4px 16px rgba(15, 24, 41, 0.06);
    --shadow-card-hover:
      0 4px 12px rgba(15, 24, 41, 0.14), 0 12px 32px rgba(15, 24, 41, 0.1);
  }

  /* ─────────────────────────────────────────
     THEME-INDEPENDENT TOKENS
  ───────────────────────────────────────── */
  :root {
    --tag-anthropic: #7c3aed;
    --tag-google: #1967d2;
    --tag-openai: #10a37f;
    --tag-meta: #0082fb;
    --tag-tools: #d97706;
    --tag-policy: #dc2626;
    --tag-default: #4b5563;

    --font-display: "Playfair Display", serif;
    --font-body: "DM Sans", sans-serif;
    --font-mono: "DM Mono", monospace;

    --radius-card: 4px;
    --max-width: 1280px;
    --gutter: clamp(16px, 4vw, 48px);
  }

  /* ─────────────────────────────────────────
     BASE RESET
  ───────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  /* Smooth transitions only AFTER initial theme is applied (prevents FOUC) */
  html.theme-ready body,
  html.theme-ready body *:not(svg):not(path) {
    transition:
      background-color 0.25s ease,
      color 0.2s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  body {
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }
  a {
    color: inherit;
    text-decoration: none;
  }

  /* ─────────────────────────────────────────
     GLOBAL FOCUS — visible in both themes
  ───────────────────────────────────────── */
  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>

<!-- Add theme-ready class after first paint so transitions don't fire on load -->
<script is:inline>
  window.addEventListener("DOMContentLoaded", function () {
    document.documentElement.classList.add("theme-ready");
  });
</script>
