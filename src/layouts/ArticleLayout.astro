---
import Layout from "./Layout.astro";
import {
  getArticlesByCategory,
  tagColor,
  categoryToSlug,
  stripMarkdown,
} from "../data/articles";
import type { Article } from "../data/articles";

export interface Props {
  article: Article;
}

const { article } = Astro.props;

const color = tagColor(article.tag);
const related = (await getArticlesByCategory(article.tag))
  .filter((a) => a.slug !== article.slug)
  .slice(0, 3);

// ── Schema constants ──────────────────────────────────────────────────────────
const siteUrl = "https://dailyaimail.com";
const articleUrl = `${siteUrl}/articles/${article.slug}`;
const pubDate = `${article.isoDate}T00:00:00+00:00`;
const modDate = `${article.modifiedDate ?? article.isoDate}T00:00:00+00:00`;
const wordCount = article.body.trim().split(/\s+/).length;
const plainBody = stripMarkdown(article.body);
const hasImage = Boolean(article.image);
const imageUrl = hasImage ? `${siteUrl}${article.image}` : null;

// ── Full @graph schema ────────────────────────────────────────────────────────
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    // 1. NewsArticle
    {
      "@type": "NewsArticle",
      "@id": `${articleUrl}#article`,
      isPartOf: { "@id": articleUrl },
      headline: article.headline,
      description: article.excerpt,
      articleBody: plainBody,
      datePublished: pubDate,
      dateModified: modDate,
      wordCount: wordCount,
      author: [{ "@id": `${siteUrl}/#/schema/person/mohamed-diab` }],
      publisher: { "@id": `${siteUrl}/#organization` },
      mainEntityOfPage: { "@id": articleUrl },
      ...(hasImage && {
        image: { "@id": `${articleUrl}#primaryimage` },
        thumbnailUrl: imageUrl,
      }),
      keywords: article.keywords,
      articleSection: article.articleSection,
      inLanguage: "en-US",
      copyrightYear: new Date(article.isoDate).getFullYear().toString(),
      copyrightHolder: { "@id": `${siteUrl}/#organization` },
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: [".article-headline", ".article-excerpt"],
      },
    },

    // 2. WebPage
    {
      "@type": "WebPage",
      "@id": articleUrl,
      url: articleUrl,
      name: `${article.headline} | Daily AI Mail`,
      isPartOf: { "@id": `${siteUrl}/#website` },
      datePublished: pubDate,
      dateModified: modDate,
      description: article.excerpt,
      breadcrumb: { "@id": `${articleUrl}#breadcrumb` },
      inLanguage: "en-US",
      ...(hasImage && {
        primaryImageOfPage: { "@id": `${articleUrl}#primaryimage` },
        image: { "@id": `${articleUrl}#primaryimage` },
        thumbnailUrl: imageUrl,
      }),
      potentialAction: [{ "@type": "ReadAction", target: [articleUrl] }],
    },

    // 3. ImageObject (only when image is declared in frontmatter)
    ...(hasImage
      ? [
          {
            "@type": "ImageObject",
            inLanguage: "en-US",
            "@id": `${articleUrl}#primaryimage`,
            url: imageUrl,
            contentUrl: imageUrl,
            width: article.imageWidth ?? 1200,
            height: article.imageHeight ?? 630,
            caption: article.imageCaption ?? article.headline,
          },
        ]
      : []),

    // 4. BreadcrumbList
    {
      "@type": "BreadcrumbList",
      "@id": `${articleUrl}#breadcrumb`,
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        {
          "@type": "ListItem",
          position: 2,
          name: article.tag,
          item: `${siteUrl}/category/${categoryToSlug(article.tag)}`,
        },
        { "@type": "ListItem", position: 3, name: article.headline },
      ],
    },

    // 5. WebSite
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: "Daily AI Mail",
      description: "Your daily source for AI news, research and tools.",
      publisher: { "@id": `${siteUrl}/#organization` },
      alternateName: "Daily AI Mail",
      potentialAction: [
        {
          "@type": "SearchAction",
          target: {
            "@type": "EntryPoint",
            urlTemplate: `${siteUrl}/?s={search_term_string}`,
          },
          "query-input": {
            "@type": "PropertyValueSpecification",
            valueRequired: true,
            valueName: "search_term_string",
          },
        },
      ],
      inLanguage: "en-US",
    },

    // 6. Organization (NewsMediaOrganization)
    {
      "@type": "NewsMediaOrganization",
      "@id": `${siteUrl}/#organization`,
      name: "Daily AI Mail",
      url: `${siteUrl}/`,
      foundingDate: "2026",
      publishingPrinciples: `${siteUrl}/publishing-principles`,
      logo: {
        "@type": "ImageObject",
        inLanguage: "en-US",
        "@id": `${siteUrl}/#/schema/logo/image/`,
        url: `${siteUrl}/logo.png`,
        contentUrl: `${siteUrl}/logo.png`,
        width: 512,
        height: 512,
        caption: "Daily AI Mail",
      },
      image: { "@id": `${siteUrl}/#/schema/logo/image/` },
      sameAs: [
        "https://twitter.com/dailyaimail",
        "https://linkedin.com/company/dailyaimail",
        "https://diab.digital",
      ],
    },

    // 7. Person (author)
    {
      "@type": "Person",
      "@id": `${siteUrl}/#/schema/person/mohamed-diab`,
      name: article.author,
      url: article.authorUrl ?? "https://interactiveseo.digital",
      description:
        "Technical SEO Consultant and founder of Daily AI Mail, with over ten years of experience covering the global AI and digital marketing industry.",
      sameAs: ["https://interactiveseo.digital", "https://diab.digital"],
    },
  ],
};
---

<Layout
  title={article.headline}
  description={article.excerpt}
  metaTitle={`${article.headline} | Daily AI Mail`}
>
  <!-- NewsArticle JSON-LD injected into <head> via Layout slot -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
    slot="head"
  />

  <!-- Article breadcrumb bar -->
  <nav
    class="article-top-bar"
    style={`background: ${color}10; border-bottom: 1px solid ${color}25;`}
  >
    <div class="article-top-inner">
      <a
        href={`/category/${categoryToSlug(article.tag)}`}
        class="back-link"
        style={`color: ${color};`}
      >
        ← {article.tag}
      </a>
    </div>
  </nav>

  <!-- Article header -->
  <header class="article-header">
    <div class="article-header-inner">
      <span
        class="article-tag"
        style={`background: ${color}18; color: ${color}; border: 1px solid ${color}35;`}
        >{article.tag}</span
      >
      <h1 class="article-headline" data-pagefind-meta="title">
        {article.headline}
      </h1>
      <p class="article-excerpt">{article.excerpt}</p>
      <div class="article-meta">
        <span class="article-author" data-pagefind-meta="author"
          >By {article.author}</span
        >
        <span class="article-sep">·</span>
        <time datetime={article.isoDate} data-pagefind-meta="date"
          >{article.date}</time
        >
        <span class="article-sep">·</span>
        <span>{article.readingTime}</span>
      </div>
    </div>
  </header>

  <!-- Hero image or gradient placeholder -->
  {
    hasImage ? (
      <figure class="article-hero-img article-hero-img--photo">
        <img
          src={article.image}
          alt={article.imageCaption ?? article.headline}
          width={article.imageWidth ?? 1200}
          height={article.imageHeight ?? 630}
          loading="eager"
        />
      </figure>
    ) : (
      <figure
        class="article-hero-img"
        style={`background: linear-gradient(135deg, ${color}15 0%, ${color}05 100%);`}
      >
        <div class="article-hero-icon" style={`color: ${color};`}>
          <svg
            width="64"
            height="64"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
          </svg>
        </div>
      </figure>
    )
  }

  <!-- Body + sidebar -->
  <main class="article-layout">
    <article class="article-body" data-pagefind-body>
      <slot />
    </article>
    <aside class="article-sidebar">
      <address class="sidebar-author-box">
        <div class="author-avatar">
          {
            article.author
              .split(" ")
              .map((n) => n[0])
              .join("")
          }
        </div>
        <div>
          <strong class="author-name">{article.author}</strong>
          <p class="author-role">Editor, Daily AI Mail</p>
        </div>
      </address>
      {
        related.length > 0 && (
          <section
            class="related-box"
            aria-label={`More articles in ${article.tag}`}
          >
            <p class="related-title">More in {article.tag}</p>
            <ul class="related-list">
              {related.map((r) => (
                <li class="related-item">
                  <a href={`/articles/${r.slug}`}>
                    <span class="related-date">{r.date}</span>
                    <span class="related-headline">{r.headline}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </aside>
  </main>
</Layout>

<style>
  .article-top-bar {
    padding: 12px 0;
  }
  .article-top-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .back-link {
    font-size: 11px;
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .back-link:hover {
    opacity: 0.7;
  }
  .article-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 48px 0 40px;
  }
  .article-header-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .article-tag {
    display: inline-block;
    font-size: 11px;
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
    align-self: flex-start;
  }
  .article-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(28px, 4.5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .article-excerpt {
    font-size: 18px;
    color: var(--color-text-muted);
    line-height: 1.6;
    font-weight: 300;
  }
  .article-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }
  .article-author {
    font-weight: 500;
    color: var(--gold);
  }
  .article-sep {
    opacity: 0.4;
  }
  .article-hero-img {
    width: 100%;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--color-border);
    margin: 0;
    overflow: hidden;
  }
  .article-hero-img--photo {
    height: auto;
  }
  .article-hero-img--photo img {
    width: 100%;
    height: auto;
    max-height: 520px;
    object-fit: cover;
    display: block;
  }
  .article-hero-icon {
    opacity: 0.25;
  }
  .article-layout {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 48px var(--gutter);
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 64px;
    align-items: start;
  }
  .article-body {
    font-size: 17px;
    line-height: 1.8;
    color: var(--color-text);
  }
  .article-body :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 26px;
    line-height: 1.2;
    margin: 40px 0 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
  }
  .article-body :global(h3) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    margin: 28px 0 12px;
    color: var(--color-text);
  }
  .article-body :global(p) {
    margin-bottom: 20px;
    color: var(--color-text);
  }
  .article-body :global(strong) {
    font-weight: 600;
    color: var(--gold);
  }
  .article-body :global(a) {
    text-decoration: underline;
    color: var(--teal);
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 20px 20px;
  }
  .article-body :global(li) {
    margin-bottom: 8px;
  }
  .article-body :global(blockquote) {
    border-left: 3px solid var(--gold);
    padding-left: 20px;
    margin: 24px 0;
    color: var(--color-text-muted);
    font-style: italic;
  }
  .article-sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .sidebar-author-box {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px;
    background: var(--card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    font-style: normal;
  }
  .author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold) 0%, #b8882a 100%);
    color: #080d1a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 900;
    flex-shrink: 0;
  }
  .author-name {
    font-weight: 600;
    font-size: 15px;
    display: block;
    color: var(--color-text);
  }
  .author-role {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--gold);
    margin-top: 3px;
    letter-spacing: 0.06em;
  }
  .related-box {
    padding: 20px;
    background: var(--card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }
  .related-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
  }
  .related-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .related-item a {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-decoration: none;
  }
  .related-date {
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .related-headline {
    font-size: 14px;
    line-height: 1.4;
    font-weight: 500;
    color: var(--color-text);
  }
  .related-item a:hover .related-headline {
    text-decoration: underline;
    color: var(--gold-light);
  }
  @media (max-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr;
    }
    .article-sidebar {
      position: static;
    }
  }
  @media (max-width: 768px) {
    .article-hero-img {
      height: 240px;
    }
  }
</style>
