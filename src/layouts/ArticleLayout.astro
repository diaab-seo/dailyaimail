---
import Layout from "./Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import {
  getArticlesByCategory,
  tagColor,
  topicToSlug,
  stripMarkdown,
} from "../data/articles";
import CommentSection from "../components/CommentSection.astro";
import type { DBComment } from "../lib/db";
import type { SessionUser } from "../lib/auth";
import type { Article } from "../data/articles";

export interface Props {
  article: Article;
  comments?: DBComment[];
  user?: SessionUser | null;
}
const { article, comments = [], user = null } = Astro.props;

const color = tagColor(article.tag);
const related = (await getArticlesByCategory(article.tag))
  .filter((a) => a.slug !== article.slug)
  .slice(0, 3);

const SITE_URL = "https://dailyaimail.news";
const articleUrl = `${SITE_URL}/articles/${article.slug}`;
const pubDate = `${article.isoDate}T00:00:00+00:00`;
const modDate = `${article.modifiedDate ?? article.isoDate}T00:00:00+00:00`;
const wordCount = article.body.trim().split(/\s+/).length;
const plainBody = stripMarkdown(article.body);
const hasImage = Boolean(article.image);
const imageUrl = hasImage ? `${SITE_URL}${article.image}` : null;
const logoUrl = `${SITE_URL}/dark-logo.svg`;

// Copy-as-Markdown content (built at server time, embedded as data)
const markdownExport = [
  `# ${article.headline}`,
  ``,
  `> ${article.excerpt}`,
  ``,
  `**Author:** ${article.author}  `,
  `**Published:** ${article.date}  `,
  `**Source:** ${articleUrl}  `,
  `**Reading time:** ${article.readingTime}`,
  ``,
  `---`,
  ``,
  article.body,
  ``,
  `---`,
  `*Originally published on [Daily AI Mail](${SITE_URL})*`,
].join("\n");

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "NewsArticle",
      "@id": `${articleUrl}#article`,
      isPartOf: { "@id": articleUrl },
      headline: article.headline,
      description: article.excerpt,
      articleBody: plainBody,
      datePublished: pubDate,
      dateModified: modDate,
      wordCount: wordCount,
      author: [{ "@id": `${SITE_URL}/#/schema/person/mohamed-diab` }],
      publisher: { "@id": `${SITE_URL}/#organization` },
      mainEntityOfPage: { "@id": articleUrl },
      ...(hasImage && {
        image: { "@id": `${articleUrl}#primaryimage` },
        thumbnailUrl: imageUrl,
      }),
      keywords: article.keywords,
      articleSection: article.articleSection,
      inLanguage: "en-US",
      copyrightYear: new Date(article.isoDate).getFullYear().toString(),
      copyrightHolder: { "@id": `${SITE_URL}/#organization` },
      speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: [".article-headline", ".article-excerpt"],
      },
      commentCount: comments.length,
    },
    {
      "@type": "WebPage",
      "@id": articleUrl,
      url: articleUrl,
      name: `${article.headline} | Daily AI Mail`,
      isPartOf: { "@id": `${SITE_URL}/#website` },
      datePublished: pubDate,
      dateModified: modDate,
      description: article.excerpt,
      breadcrumb: { "@id": `${articleUrl}#breadcrumb` },
      inLanguage: "en-US",
      ...(hasImage && {
        primaryImageOfPage: { "@id": `${articleUrl}#primaryimage` },
        image: { "@id": `${articleUrl}#primaryimage` },
        thumbnailUrl: imageUrl,
      }),
      potentialAction: [{ "@type": "ReadAction", target: [articleUrl] }],
    },
    ...(hasImage
      ? [
          {
            "@type": "ImageObject",
            inLanguage: "en-US",
            "@id": `${articleUrl}#primaryimage`,
            url: imageUrl,
            contentUrl: imageUrl,
            width: article.imageWidth ?? 1200,
            height: article.imageHeight ?? 630,
            caption: article.imageCaption ?? article.headline,
          },
        ]
      : []),
    {
      "@type": "BreadcrumbList",
      "@id": `${articleUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: `${SITE_URL}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Topics",
          item: `${SITE_URL}/topics`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: article.tag,
          item: `${SITE_URL}/topics/${topicToSlug(article.tag)}`,
        },
        { "@type": "ListItem", position: 4, name: article.headline },
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      url: `${SITE_URL}/`,
      name: "Daily AI Mail",
      publisher: { "@id": `${SITE_URL}/#organization` },
      inLanguage: "en-US",
    },
    {
      "@type": "NewsMediaOrganization",
      "@id": `${SITE_URL}/#organization`,
      name: "Daily AI Mail",
      url: `${SITE_URL}/`,
      foundingDate: "2026",
      publishingPrinciples: `${SITE_URL}/publishing-principles`,
      logo: {
        "@type": "ImageObject",
        "@id": `${SITE_URL}/#/schema/logo/image/`,
        url: logoUrl,
        contentUrl: logoUrl,
        width: 512,
        height: 512,
        caption: "Daily AI Mail",
      },
      image: { "@id": `${SITE_URL}/#/schema/logo/image/` },
      sameAs: [
        "https://twitter.com/dailyaimail",
        "https://linkedin.com/company/dailyaimail",
        "https://diab.digital",
      ],
    },
    {
      "@type": "Person",
      "@id": `${SITE_URL}/#/schema/person/mohamed-diab`,
      name: article.author,
      url: `${SITE_URL}/author/mohamed-diab`,
      description: "Technical SEO Consultant and founder of Daily AI Mail.",
      sameAs: ["https://interactiveseo.digital", "https://diab.digital"],
    },
    // Comment nodes — only injected when approved comments exist
    ...comments.map((c) => ({
      "@type": "Comment",
      "@id": `${articleUrl}#comment-${c.id}`,
      identifier: String(c.id),
      text: c.body,
      dateCreated: c.created_at,
      author: {
        "@type": "Person",
        name: c.display_name ?? "Anonymous",
      },
      about: { "@id": `${articleUrl}#article` },
      isPartOf: { "@id": articleUrl },
      url: `${articleUrl}#comment-${c.id}`,
    })),
  ],
};
---

<Layout
  title={article.headline}
  description={article.excerpt}
  metaTitle={`${article.headline} | Daily AI Mail`}
  canonical={articleUrl}
  ogType="article"
  ogTitle={article.headline}
  ogDescription={article.excerpt}
  ogImage={hasImage ? imageUrl! : undefined}
  ogPublished={pubDate}
  ogModified={modDate}
  ogAuthor={article.author}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
    slot="head"
  />

  <!-- Breadcrumb -->
  <Breadcrumb
    items={[
      { label: "Home", href: "/" },
      { label: "Topics", href: "/topics" },
      { label: article.tag, href: `/topics/${topicToSlug(article.tag)}` },
      { label: article.headline },
    ]}
  />

  <!-- Article header -->
  <header class="article-header">
    <div class="article-header-inner">
      <span
        class="article-tag"
        style={`background:${color}18;color:${color};border:1px solid ${color}35;`}
        >{article.tag}</span
      >
      <h1 class="article-headline" data-pagefind-meta="title">
        {article.headline}
      </h1>
      <p class="article-excerpt">{article.excerpt}</p>
      <div class="article-meta">
        <span class="article-author" data-pagefind-meta="author"
          >By <a href="/author/mohamed-diab">{article.author}</a></span
        >
        <span class="article-sep">·</span>
        <time datetime={article.isoDate} data-pagefind-meta="date"
          >{article.date}</time
        >
        <span class="article-sep">·</span>
        <span>{article.readingTime}</span>
      </div>

      <!-- Action bar: Share (collapsed) + Copy as Markdown -->
      <div class="action-bar">
        <!-- Share toggle button -->
        <div class="share-wrapper">
          <button
            class="action-btn share-toggle"
            id="share-toggle"
            aria-expanded="false"
            aria-controls="share-popover"
            data-url={articleUrl}
            data-title={article.headline}
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><circle cx="18" cy="5" r="3"></circle><circle
                cx="6"
                cy="12"
                r="3"></circle><circle cx="18" cy="19" r="3"></circle><line
                x1="8.59"
                y1="13.51"
                x2="15.42"
                y2="17.49"></line><line
                x1="15.41"
                y1="6.51"
                x2="8.59"
                y2="10.49"></line></svg
            >
            <span>Share</span>
            <svg
              class="chevron"
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><polyline points="6 9 12 15 18 9"></polyline></svg
            >
          </button>

          <!-- Share popover -->
          <div
            class="share-popover"
            id="share-popover"
            role="dialog"
            aria-label="Share options"
            hidden
          >
            <button class="share-item share-item--copy" id="copy-link-btn">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
                  d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                ></path></svg
              >
              Copy link
            </button>
            <a
              class="share-item share-item--x"
              id="share-x"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path></svg
              >
              X / Twitter
            </a>
            <a
              class="share-item share-item--li"
              id="share-li"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                  cx="4"
                  cy="4"
                  r="2"></circle></svg
              >
              LinkedIn
            </a>
            <a
              class="share-item share-item--wa"
              id="share-wa"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"
                ></path></svg
              >
              WhatsApp
            </a>
            <a
              class="share-item share-item--fb"
              id="share-fb"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                ></path></svg
              >
              Facebook
            </a>
            <span class="copy-toast" id="copy-toast">Copied!</span>
          </div>
        </div>

        <!-- Copy as Markdown — always visible, for LLMs & AI tools -->
        <button
          class="action-btn copy-md-btn"
          id="copy-md-btn"
          title="Copy article as Markdown — for use with LLMs and AI tools"
        >
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path
              d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
            ></path><polyline points="14 2 14 8 20 8"></polyline><line
              x1="16"
              y1="13"
              x2="8"
              y2="13"></line><line x1="16" y1="17" x2="8" y2="17"
            ></line><polyline points="10 9 9 9 8 9"></polyline></svg
          >
          <span>Copy as Markdown</span>
        </button>
        <span class="md-toast" id="md-toast">Copied as Markdown!</span>

        <!-- Hidden markdown payload -->
        <template id="article-markdown">{markdownExport}</template>
      </div>
    </div>
  </header>

  <!-- Hero image or gradient placeholder -->
  {
    hasImage ? (
      <figure class="article-hero-img article-hero-img--photo">
        <img
          src={article.image}
          alt={article.imageCaption ?? article.headline}
          width={article.imageWidth ?? 1200}
          height={article.imageHeight ?? 630}
          loading="eager"
        />
      </figure>
    ) : (
      <figure
        class="article-hero-img"
        style={`background:linear-gradient(135deg,${color}15 0%,${color}05 100%);`}
      >
        <div class="article-hero-icon" style={`color:${color};`}>
          <svg
            width="64"
            height="64"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
          </svg>
        </div>
      </figure>
    )
  }

  <!-- Body + Sidebar -->
  <main class="article-layout">
    <article class="article-body" data-pagefind-body>
      <slot />

      <!-- Filed Under -->
      <footer class="filed-under">
        <span class="filed-label">Filed under</span>
        <div class="filed-tags">
          {
            article.tags.map((t) => (
              <a
                href={`/topics/${topicToSlug(t)}`}
                class="filed-tag"
                style={`background:${tagColor(t)}15;color:${tagColor(t)};border:1px solid ${tagColor(t)}35;`}
              >
                {t}
              </a>
            ))
          }
        </div>
      </footer>

      <CommentSection
        articleSlug={article.slug}
        comments={comments}
        user={user}
      />
    </article>

    <aside class="article-sidebar">
      <address class="sidebar-author-box">
        <a href="/author/mohamed-diab" class="author-avatar">
          {
            article.author
              .split(" ")
              .map((n) => n[0])
              .join("")
          }
        </a>
        <div>
          <strong class="author-name"><a href="/author/mohamed-diab">{article.author}</a></strong>
          <p class="author-role">Editor, Daily AI Mail</p>
        </div>
      </address>

      <!-- Google Preferred Source -->
      <div class="google-badge-widget">
        <p class="google-badge-hint">
          Follow us on Google for daily AI updates
        </p>
        <a
          href="https://google.com/preferences/source?q=dailyaimail.news"
          target="_blank"
          rel="noopener noreferrer"
          class="google-badge-link"
          aria-label="Add Daily AI Mail as a preferred source on Google"
        >
          <img
            id="google-badge-img"
            src="/badges/google_preferred_source_badge_dark.png"
            alt="Add as a preferred source on Google"
            width="196"
            height="40"
            class="google-badge"
          />
        </a>
      </div>

      <!-- Related -->
      {
        related.length > 0 && (
          <section
            class="related-box"
            aria-label={`More articles in ${article.tag}`}
          >
            <p class="related-title">More in {article.tag}</p>
            <ul class="related-list">
              {related.map((r) => (
                <li class="related-item">
                  <a href={`/articles/${r.slug}`}>
                    <span class="related-date">{r.date}</span>
                    <span class="related-headline">{r.headline}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </aside>
  </main>
</Layout>

<script>
  // ── Share popover ───────────────────────────────────────────────────────────
  const toggle = document.getElementById("share-toggle") as HTMLButtonElement;
  const popover = document.getElementById("share-popover") as HTMLElement;

  if (toggle && popover) {
    const url = toggle.dataset.url ?? location.href;
    const title = toggle.dataset.title ?? document.title;
    const enc = encodeURIComponent;

    // Wire up links
    (document.getElementById("share-x") as HTMLAnchorElement).href =
      `https://x.com/intent/tweet?text=${enc(title)}&url=${enc(url)}`;
    (document.getElementById("share-li") as HTMLAnchorElement).href =
      `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}`;
    (document.getElementById("share-wa") as HTMLAnchorElement).href =
      `https://wa.me/?text=${enc(title + " " + url)}`;
    (document.getElementById("share-fb") as HTMLAnchorElement).href =
      `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}`;

    // Toggle open/close
    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = popover.hidden === false;
      popover.hidden = open;
      toggle.setAttribute("aria-expanded", String(!open));
    });

    // Close on outside click
    document.addEventListener("click", (e) => {
      if (!popover.contains(e.target as Node) && e.target !== toggle) {
        popover.hidden = true;
        toggle.setAttribute("aria-expanded", "false");
      }
    });

    // Copy link
    const copyLinkBtn = document.getElementById("copy-link-btn")!;
    const copyToast = document.getElementById("copy-toast")!;
    copyLinkBtn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(url);
        copyToast.classList.add("visible");
        setTimeout(() => copyToast.classList.remove("visible"), 2000);
      } catch {}
    });
  }

  // ── Copy as Markdown ────────────────────────────────────────────────────────
  const mdBtn = document.getElementById("copy-md-btn")!;
  const mdToast = document.getElementById("md-toast")!;
  const mdTpl = document.getElementById(
    "article-markdown",
  ) as HTMLTemplateElement;

  mdBtn?.addEventListener("click", async () => {
    try {
      const markdown = mdTpl?.innerHTML ?? "";
      await navigator.clipboard.writeText(markdown);
      mdToast.classList.add("visible");
      setTimeout(() => mdToast.classList.remove("visible"), 2500);
    } catch {}
  });

  // ── Google badge theme swap ─────────────────────────────────────────────────
  function updateBadge() {
    const img = document.getElementById(
      "google-badge-img",
    ) as HTMLImageElement | null;
    if (!img) return;
    const theme = document.documentElement.getAttribute("data-theme") ?? "dark";
    img.src = `/badges/google_preferred_source_badge_${theme === "light" ? "light" : "dark"}.png`;
  }
  updateBadge();
  new MutationObserver(updateBadge).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });
</script>

<style>
  .article-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 40px 0 32px;
  }
  .article-header-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .article-tag {
    display: inline-block;
    font-size: 11px;
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
    align-self: flex-start;
  }
  .article-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(28px, 4.5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .article-excerpt {
    font-size: 18px;
    color: var(--color-text-muted);
    line-height: 1.6;
    font-weight: 300;
  }
  .article-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }
  .article-author {
    font-weight: 500;
    color: var(--gold);
  }
  .article-author a {
    color: inherit;
    text-decoration: none;
  }
  .article-author a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .article-sep {
    opacity: 0.4;
  }

  /* Action bar */
  .action-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
    position: relative;
    flex-wrap: wrap;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: transparent;
