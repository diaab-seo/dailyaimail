    </div>

    <div class="footer-bottom">
      <p class="copyright">© 2026 Daily AI Mail · Built by Mohamed Diab</p>
      <nav class="legal-links" aria-label="Legal">
        <a href="/privacy-policy">Privacy Policy</a>
        <span class="sep">·</span>
        <a href="/terms-and-conditions">Terms of Use</a>
        <span class="sep">·</span>
        <a href="/cookies-policy">Cookies Policy</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--nav-bg);
    color: var(--nav-text);
    padding: 60px var(--gutter) 32px;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 48px;
    margin-bottom: 60px;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 26px;
    text-decoration: none;
    color: var(--nav-text);
    display: block;
    margin-bottom: 16px;
  }
  .footer-logo em {
    font-style: italic;
  }
  .tagline {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15px;
    line-height: 1.5;
  }
  .links-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .footer-col-heading {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 20px;
    color: white;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-col ul a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
    transition: opacity 0.2s;
  }
  .footer-col ul a:hover {
    opacity: 1;
    color: white;
  }
  .all-topics-item {
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .all-topics-item a {
    color: var(--gold) !important;
    font-weight: 500;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
  }
  .legal-links a {
    color: rgba(255, 255, 255, 0.6);
    transition: opacity 0.2s;
  }
  .legal-links a:hover {
    color: white;
  }
  .sep {
    margin: 0 8px;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }
</style>
