<!-- Search Modal — position:fixed, JS controls display, never affects page layout -->
<div
  id="search-modal"
  class="search-modal"
  aria-modal="true"
  role="dialog"
  aria-label="Search Daily AI Mail"
>
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-container">
    <div id="search"></div>
  </div>
</div>

<script>
  // ── Auth state → avatar button + mobile nav ─────────────────────────────────
  (async () => {
    try {
      const res  = await fetch('/api/me');
      const { user } = await res.json() as { user: { displayName: string | null; avatarInitials?: string | null } | null };

      const avatarBtn      = document.getElementById('avatar-btn');
      const avatarInitials = document.getElementById('avatar-initials');
      const avatarIcon     = document.getElementById('avatar-icon');
      const avatarGuest    = document.getElementById('avatar-guest');
      const avatarUser     = document.getElementById('avatar-user');
      const avatarName     = document.getElementById('avatar-display-name');

      // Mobile
      const mobileSignin   = document.getElementById('mobile-signin-item');
      const mobileRegister = document.getElementById('mobile-register-item');
      const mobileLogout   = document.getElementById('mobile-logout-item');

      if (user && user.displayName) {
        // ── Logged in ──────────────────────────────────────────────────────────
        const initials = user.avatarInitials || (user.displayName as string).split(' ').map((n: string) => n[0]).join('').toUpperCase().slice(0, 2);
        if (avatarInitials) avatarInitials.textContent = initials;
        if (avatarBtn)      avatarBtn.classList.add('is-logged-in');
        if (avatarBtn)      avatarBtn.setAttribute('aria-label', user.displayName);
        if (avatarGuest)    avatarGuest.style.display = 'none';
        if (avatarUser)     avatarUser.style.display  = '';
        if (avatarName)     avatarName.textContent     = user.displayName;
        // Mobile
        if (mobileSignin)   mobileSignin.style.display   = 'none';
        if (mobileRegister) mobileRegister.style.display = 'none';
        if (mobileLogout)   mobileLogout.style.display   = '';
      } else {
        // ── Logged out ─────────────────────────────────────────────────────────
        if (avatarGuest) avatarGuest.style.display = '';
        if (avatarUser)  avatarUser.style.display  = 'none';
        // Mobile already shows sign in by default
      }
    } catch {
      // Silently fail
    }
  })();

  // ── Avatar dropdown toggle ──────────────────────────────────────────────────
  const avatarBtn      = document.getElementById('avatar-btn');
  const avatarDropdown = document.getElementById('avatar-dropdown');

  if (avatarBtn && avatarDropdown) {
    avatarBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !avatarDropdown.hidden;
      avatarDropdown.hidden = isOpen;
      avatarBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    document.addEventListener('click', (e) => {
      if (!avatarDropdown.hidden && !avatarDropdown.contains(e.target as Node)) {
        avatarDropdown.hidden = true;
        avatarBtn.setAttribute('aria-expanded', 'false');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === "Escape" && !avatarDropdown.hidden) {
        avatarDropdown.hidden = true;
        avatarBtn.setAttribute('aria-expanded', 'false');
        avatarBtn.focus();
      }
    });
  }
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // ── Force modal hidden on init (JS-controlled, no CSS [hidden] attribute) ──
    const searchModal = document.getElementById(
      "search-modal",
    ) as HTMLElement | null;
    if (searchModal) searchModal.style.display = "none";

    // ── Hamburger ──────────────────────────────────────────────────────────────
    const hamburgerBtn = document.getElementById("hamburger-btn");
    const mainNav = document.getElementById("main-nav");

    if (hamburgerBtn && mainNav) {
      hamburgerBtn.addEventListener("click", () => {
        const isOpen = mainNav.hasAttribute("data-open");
        mainNav.toggleAttribute("data-open");
        hamburgerBtn.setAttribute("aria-expanded", String(!isOpen));
        hamburgerBtn.setAttribute(
          "aria-label",
          isOpen ? "Open menu" : "Close menu",
        );
      });
    }

    // ── Theme toggle ───────────────────────────────────────────────────────────
    function applyTheme(pref: string) {
      const root = document.documentElement;
      let resolved = pref;
      if (pref === "system") {
        resolved = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      }
      root.setAttribute("data-theme", resolved);
      root.setAttribute("data-theme-pref", pref);
      localStorage.setItem("dai-theme", pref);
      document
        .querySelectorAll<HTMLButtonElement>("[data-theme-val]")
        .forEach((btn) => {
          btn.setAttribute(
            "aria-pressed",
            String(btn.dataset.themeVal === pref),
          );
        });
    }

    const saved = localStorage.getItem("dai-theme") || "system";
    document
      .querySelectorAll<HTMLButtonElement>("[data-theme-val]")
      .forEach((btn) => {
        btn.setAttribute(
          "aria-pressed",
          String(btn.dataset.themeVal === saved),
        );
        btn.addEventListener("click", () => applyTheme(btn.dataset.themeVal!));
      });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        const pref = localStorage.getItem("dai-theme") || "system";
        if (pref === "system") applyTheme("system");
      });

    // ── Search modal ───────────────────────────────────────────────────────────
    const searchOpenBtn = document.getElementById("search-open-btn");
    const searchBackdrop = document.getElementById("search-backdrop");
    const searchEl = document.getElementById("search");

    if (!searchOpenBtn || !searchModal || !searchEl) return;

    let pagefindInitialised = false;

    function openSearch() {
      searchModal!.style.display = "flex";
      document.body.style.overflow = "hidden";

      if (pagefindInitialised) {
        searchModal!
          .querySelector<HTMLInputElement>("input[type=text]")
          ?.focus();
        return;
      }

      const isDev =
        window.location.hostname === "localhost" ||
        window.location.hostname === "127.0.0.1";

      if (isDev) {
        searchEl!.innerHTML = `
          <div style="padding:32px 24px;color:#8a95a8;font-size:14px;
                      font-family:var(--font-mono);text-align:center;line-height:1.9;">
            <div style="font-size:32px;margin-bottom:12px;">🔍</div>
            Search requires a production build.<br/>
            Run <code style="color:#e8b84b;background:rgba(232,184,75,0.1);
                             padding:2px 8px;border-radius:4px;">
              npm run build &amp;&amp; npm run preview
            </code><br/>to test search locally.
          </div>`;
        pagefindInitialised = true;
        return;
      }

      // Production — lazy-load pagefind
      const pagefindPath = ["", "pagefind", "pagefind-ui.js"].join("/");
      // @ts-ignore
      import(/* @vite-ignore */ pagefindPath)
        .then(({ PagefindUI }) => {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            showImages: false,
            resetStyles: false,
          });
          pagefindInitialised = true;
          setTimeout(() => {
            searchModal!
              .querySelector<HTMLInputElement>("input[type=text]")
              ?.focus();
          }, 50);
        })
        .catch((e: unknown) => {
          console.warn("[Search] Pagefind failed to load:", e);
          searchEl!.innerHTML = `
          <div style="padding:24px;color:#8a95a8;text-align:center;
                      font-family:var(--font-mono);font-size:14px;">
            Search index not available.
          </div>`;
        });
    }

    function closeSearch() {
      searchModal!.style.display = "none";
      document.body.style.overflow = "";
    }

    searchOpenBtn.addEventListener("click", openSearch);
    searchBackdrop?.addEventListener("click", closeSearch);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeSearch();
      if (e.key === "k" && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        openSearch();
      }
    });
  });
</script>

<style>
  /* ── Navbar shell ─────────────────────────── */
  .navbar {
    background: var(--nav-bg);
    color: var(--nav-text);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(232, 184, 75, 0.1);
  }
  .navbar-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* ── Logo ─────────────────────────────────── */
  .navbar-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .navbar-logo .logo-dark,
  .navbar-logo .logo-light {
    display: none;
    height: 38px;
    width: auto;
  }

  /* 
     Shared Mapping:
     Using dark-logo.svg (white text) for both themes
     because the header remains dark in both modes.
  */
  :global([data-theme="dark"]) .navbar-logo .logo-dark { display: block; }
  :global([data-theme="light"]) .navbar-logo .logo-dark { display: block; }

  /* Fallback */
  :root:not([data-theme]) .logo-dark { display: block; }

  /* ── Desktop nav links ───────────────────── */
  .desktop-nav {
    display: flex;
    list-style: none;
    gap: 4px;
    margin: 0;
    padding: 0;
    flex: 1;
    justify-content: center;
  }
  .desktop-nav > li {
    position: relative;
  }
  .desktop-nav > li > a {
    display: block;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 6px;
    color: rgba(244, 240, 232, 0.75);
    transition:
      color 0.15s,
      background 0.15s;
    white-space: nowrap;
  }
  .desktop-nav > li > a:hover {
    color: #f4f0e8;
    background: rgba(255, 255, 255, 0.07);
  }

  /* ── Dropdown ─────────────────────────────── */
  .has-dropdown .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: #111828;
    border: 1px solid rgba(232, 184, 75, 0.15);
    padding: 6px;
    border-radius: 8px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
    list-style: none;
    min-width: 188px;
    z-index: 200;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: block;
  }
  .dropdown li a {
    display: block;
    font-size: 13.5px;
