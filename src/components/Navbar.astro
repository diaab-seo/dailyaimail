<SearchModal />

<script is:inline>
  // ── Search button → open modal ──────────────────────────────
  document
    .getElementById("search-open-btn")
    .addEventListener("click", function () {
      window.__openSearch && window.__openSearch();
    });

  // ── Hamburger ──────────────────────────────────
  var hamburgerBtn = document.getElementById("hamburger-btn");
  var mainNav = document.getElementById("main-nav");

  if (hamburgerBtn && mainNav) {
    hamburgerBtn.addEventListener("click", function () {
      var isOpen = mainNav.hasAttribute("data-open");
      mainNav.toggleAttribute("data-open");
      hamburgerBtn.setAttribute("aria-expanded", String(!isOpen));
      hamburgerBtn.setAttribute(
        "aria-label",
        isOpen ? "Open menu" : "Close menu",
      );
    });
  }

  // ── Theme toggle ───────────────────────────────
  function applyTheme(pref) {
    var root = document.documentElement;
    var resolved = pref;
    if (pref === "system") {
      resolved = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    }
    root.setAttribute("data-theme", resolved);
    root.setAttribute("data-theme-pref", pref);
    localStorage.setItem("dai-theme", pref);

    document.querySelectorAll("[data-theme-val]").forEach(function (btn) {
      btn.setAttribute("aria-pressed", String(btn.dataset.themeVal === pref));
    });
  }

  // Init button states from saved preference
  var saved = localStorage.getItem("dai-theme") || "system";
  document.querySelectorAll("[data-theme-val]").forEach(function (btn) {
    btn.setAttribute("aria-pressed", String(btn.dataset.themeVal === saved));
  });

  // Click handlers
  document.querySelectorAll("[data-theme-val]").forEach(function (btn) {
    btn.addEventListener("click", function () {
      applyTheme(btn.dataset.themeVal);
    });
  });

  // Respond to OS-level theme change when user is on "system"
  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", function () {
      var pref = localStorage.getItem("dai-theme") || "system";
      if (pref === "system") applyTheme("system");
    });
</script>

<style>
  /* ── Navbar shell ─────────────────────────── */
  .navbar {
    background: var(--nav-bg);
    color: var(--nav-text);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(232, 184, 75, 0.1);
  }
  .navbar-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* ── Logo ─────────────────────────────────── */
  .navbar-logo {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 900;
    text-decoration: none;
    color: var(--nav-text);
    flex-shrink: 0;
    letter-spacing: -0.01em;
  }
  .navbar-logo em {
    font-style: italic;
    color: #e8b84b; /* always gold regardless of theme — nav is always dark */
  }

  /* ── Desktop nav links ───────────────────── */
  .desktop-nav {
    display: flex;
    list-style: none;
    gap: 4px;
    margin: 0;
    padding: 0;
    flex: 1;
    justify-content: center;
  }
  .desktop-nav > li {
    position: relative;
  }
  .desktop-nav > li > a {
    display: block;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 6px;
    color: rgba(244, 240, 232, 0.75);
    transition:
      color 0.15s,
      background 0.15s;
    white-space: nowrap;
  }
  .desktop-nav > li > a:hover {
    color: #f4f0e8;
    background: rgba(255, 255, 255, 0.07);
  }

  /* ── Dropdown ─────────────────────────────── */
  .has-dropdown .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: #111828;
    border: 1px solid rgba(232, 184, 75, 0.15);
    padding: 6px;
    border-radius: 8px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
    list-style: none;
    min-width: 188px;
    z-index: 200;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: block;
  }
  .dropdown li a {
    display: block;
    font-size: 13.5px;
    padding: 9px 14px;
    border-radius: 5px;
    color: rgba(244, 240, 232, 0.75);
    transition:
      background 0.15s,
      color 0.15s;
  }
  .dropdown li a:hover {
    background: rgba(232, 184, 75, 0.09);
    color: #e8b84b;
  }

  /* ── Nav actions (right side) ────────────── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* ── Icon buttons (search / subscribe) ───── */
  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid rgba(244, 240, 232, 0.12);
    border-radius: 8px;
    color: rgba(244, 240, 232, 0.7);
    cursor: pointer;
    transition:
      color 0.15s,
      border-color 0.15s,
      background 0.15s;
  }
  .icon-btn:hover {
    color: #f4f0e8;
    border-color: rgba(232, 184, 75, 0.4);
    background: rgba(232, 184, 75, 0.07);
  }

  /* Keyboard shortcut hint on search button */
  .search-trigger {
    width: auto;
    padding: 0 10px;
    gap: 7px;
  }
  .search-kbd-hint {
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgba(244, 240, 232, 0.35);
    letter-spacing: 0.04em;
  }
  @media (max-width: 900px) {
    .search-kbd-hint {
      display: none;
    }
    .search-trigger {
      width: 36px;
      padding: 0;
    }
  }

  /* ── Theme toggle ─────────────────────────── */
  .theme-toggle {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(244, 240, 232, 0.1);
    border-radius: 8px;
    padding: 3px;
    gap: 1px;
  }
  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 30px;
    height: 28px;
    background: none;
    border: none;
    border-radius: 5px;
    color: rgba(244, 240, 232, 0.45);
    cursor: pointer;
    transition:
      color 0.15s,
      background 0.15s;
    padding: 0 6px;
  }
  .theme-btn:hover {
    color: rgba(244, 240, 232, 0.85);
    background: rgba(255, 255, 255, 0.06);
  }
  /* Active state — aria-pressed="true" */
  .theme-btn[aria-pressed="true"] {
    background: rgba(232, 184, 75, 0.15);
    color: #e8b84b;
  }

  /* ── Hamburger (mobile only) ─────────────── */
  .hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid rgba(244, 240, 232, 0.12);
    border-radius: 8px;
    color: rgba(244, 240, 232, 0.8);
    cursor: pointer;
    transition:
      color 0.15s,
      border-color 0.15s;
  }
  .hamburger:hover {
    color: #f4f0e8;
    border-color: rgba(232, 184, 75, 0.4);
  }

  /* ── Mobile nav ───────────────────────────── */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px var(--gutter) 16px;
    margin: 0;
    list-style: none;
    background: #0a1020;
    border-top: 1px solid rgba(232, 184, 75, 0.1);
  }
  .mobile-nav li a {
    display: block;
    padding: 13px 0;
    font-size: 15px;
    font-weight: 500;
    color: rgba(244, 240, 232, 0.75);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: color 0.15s;
  }
  .mobile-nav li a:hover {
    color: #e8b84b;
  }

  /* Mobile theme row */
  .mobile-theme-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0 4px;
  }
  .mobile-theme-label {
    font-size: 12px;
    font-family: var(--font-mono);
    color: rgba(244, 240, 232, 0.4);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .theme-toggle--mobile {
    background: rgba(255, 255, 255, 0.05);
  }
  .theme-toggle--mobile .theme-btn {
    width: auto;
    padding: 0 10px;
    height: 30px;
    font-size: 12px;
    font-family: var(--font-mono);
    gap: 6px;
  }
  .theme-toggle--mobile .theme-btn span {
    letter-spacing: 0.04em;
    font-size: 11px;
  }

  /* ── Open state ───────────────────────────── */
  nav[data-open] .mobile-nav {
    display: flex;
  }
  nav[data-open] .hamburger {
    color: #e8b84b;
    border-color: rgba(232, 184, 75, 0.4);
  }

  /* ── Responsive ───────────────────────────── */
  @media (max-width: 1100px) {
    .desktop-nav > li > a {
      font-size: 13px;
      padding: 8px 8px;
    }
  }
  @media (max-width: 900px) {
    .desktop-nav {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>
