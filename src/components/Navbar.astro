<style>
  .navbar {
    background: var(--nav-bg);
    color: var(--nav-text);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .navbar-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .navbar-logo {
    font-family: var(--font-display);
    font-size: 22px;
    text-decoration: none;
    color: var(--nav-text);
  }
  .navbar-logo em {
    font-style: italic;
  }
  .desktop-nav {
    display: flex;
    list-style: none;
    gap: 24px;
    margin: 0;
    padding: 0;
  }
  .desktop-nav > li {
    position: relative;
  }
  .desktop-nav > li > a {
    font-size: 15px;
    font-weight: 500;
    padding: 12px 0;
    color: rgba(255,255,255,0.8);
    transition: color 0.2s;
  }
  .desktop-nav > li > a:hover {
    color: white;
  }
  .has-dropdown .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #1A1A18;
    padding: 8px 0;
    border-radius: 4px;
    box-shadow: 0 10px 24px rgba(0,0,0,0.2);
    list-style: none;
    min-width: 180px;
  }
  .has-dropdown:hover .dropdown {
    display: block;
  }
  .dropdown li a {
    display: block;
    font-size: 14px;
    padding: 10px 20px;
    color: rgba(255,255,255,0.8);
    transition: background 0.2s;
  }
  .dropdown li a:hover {
    background: rgba(255,255,255,0.06);
    color: white;
  }
  .nav-actions {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .icon-btn {
    background: none;
    border: none;
    color: var(--nav-text);
    font-size: 18px;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--nav-text);
    font-size: 24px;
    cursor: pointer;
    padding: 4px;
  }
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 16px var(--gutter);
    background: var(--nav-bg);
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .mobile-nav a {
    padding: 12px 0;
    font-size: 16px;
    color: white;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  
  nav[data-open] .mobile-nav {
    display: flex;
  }

  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }
    .hamburger {
      display: block;
    }
  }
</style>
