---
export interface Props {
  tag: string;
  headline: string;
  excerpt: string;
  date: string;
  author?: string;
  image?: string;
  href?: string;
  readingTime?: string;
}

const {
  tag,
  headline,
  excerpt,
  date,
  author,
  image,
  href = "#",
  readingTime,
} = Astro.props;

const tagColors: Record<string, string> = {
  Anthropic: "#9D6FFF",
  "Google AI": "#4D8EF0",
  OpenAI: "#19C99B",
  "Meta AI": "#3AABFF",
  "Tools & Apps": "#F0A030",
  "Policy & Ethics": "#F05050",
};
const color = tagColors[tag] ?? "#8A95A8";
---

<a href={href} class="news-card">
  <figure
    class="card-img"
    style={`background: linear-gradient(135deg, ${color}18 0%, ${color}08 100%); border-bottom: 1px solid ${color}30;`}
  >
    {
      image ? (
        <img
          src={image}
          alt={headline}
          width="400"
          height="220"
          loading="lazy"
        />
      ) : (
        <div class="card-img-icon" style={`color: ${color};`}>
          <svg
            width="36"
            height="36"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
          </svg>
        </div>
      )
    }
  </figure>

  <div class="card-body">
    <span class="card-tag" style={`background: ${color}20; color: ${color};`}
      >{tag}</span
    >
    <h3 class="card-headline">{headline}</h3>
    <p class="card-excerpt">{excerpt}</p>
    <footer class="card-footer">
      <span class="card-date"
        >{date}{readingTime ? ` · ${readingTime}` : ""}</span
      >
      <span class="card-cta">View More →</span>
    </footer>
  </div>
</a>

<style>
  .news-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
    box-shadow: var(--shadow-card);
    height: 100%;
  }
  .news-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
    border-color: rgba(232, 184, 75, 0.35);
  }
  .card-img {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    margin: 0;
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-img-icon {
    opacity: 0.5;
  }

  .card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }
  .card-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
    align-self: flex-start;
  }
  .card-headline {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-excerpt {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 12px;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }
  .card-date {
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }
  .card-cta {
    font-size: 12px;
    font-weight: 500;
    color: var(--gold);
  }
  .news-card:hover .card-cta {
    text-decoration: underline;
  }
</style>
