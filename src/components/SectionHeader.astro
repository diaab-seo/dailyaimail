---
interface Props {
  title: string;
  viewAllHref?: string;
  viewAllLabel?: string;
}

const { title, viewAllHref, viewAllLabel } = Astro.props;
---

<header class="section-header">
  <div class="header-row">
    <h2 class="title">{title}</h2>
    {
      viewAllHref && viewAllLabel && (
        <a href={viewAllHref} class="view-all">
          {viewAllLabel}
        </a>
      )
    }
  </div>
  <hr class="divider" />
</header>

<style>
  .section-header {
    margin-bottom: 24px;
  }
  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 12px;
  }
  .title {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--color-text);
  }
  .view-all {
    font-size: 14px;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }
  .view-all:hover {
    color: var(--color-text);
  }
  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }
</style>
