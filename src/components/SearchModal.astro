---

---

<!-- Search modal overlay -->
<div
    id="search-modal"
    class="search-modal"
    role="dialog"
    aria-modal="true"
    aria-label="Search articles"
    hidden
>
    <div class="search-backdrop" id="search-backdrop"></div>
    <div class="search-panel">
        <div class="search-panel-header">
            <span class="search-panel-label">Search Daily AI Mail</span>
            <button
                class="search-close"
                id="search-close"
                aria-label="Close search"
            >
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    aria-hidden="true"
                    focusable="false"
                >
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>

        <!-- Pagefind UI mounts here -->
        <div id="search-container"></div>

        <p class="search-hint">
            <kbd>↑</kbd><kbd>↓</kbd> navigate &nbsp;·&nbsp;
            <kbd>Enter</kbd> open &nbsp;·&nbsp;
            <kbd>Esc</kbd> close
        </p>
    </div>
</div>

<!-- Load Pagefind UI via plain script tags — NOT processed by Vite/Astro bundler -->
<link rel="stylesheet" href="/_pagefind/pagefind-ui.css" />
<script is:inline src="/_pagefind/pagefind-ui.js"></script>

<script is:inline>
    // ── Pagefind UI init ────────────────────────────────────────
    function initPagefind() {
        try {
            new PagefindUI({
                element: "#search-container",
                showSubResults: false,
                showImages: false,
                resetStyles: false,
                excerptLength: 20,
                translations: {
                    placeholder: "Search articles, topics, or companies…",
                    zero_results: 'No results for "[SEARCH_TERM]"',
                },
            });
        } catch (e) {
            // Pagefind is not available — show dev-mode message
            document.getElementById("search-container").innerHTML =
                '<p style="padding:24px 16px;text-align:center;font-family:var(--font-mono);font-size:13px;color:var(--color-text-muted)">' +
                "Search index not built yet.<br><br>" +
                'Run <strong style="color:var(--color-accent);font-weight:600">npm run build</strong> to generate the search index, then use <strong style="color:var(--color-accent);font-weight:600">npm run preview</strong> to test search.' +
                "</p>";
        }
    }

    // ── Modal open / close ───────────────────────────────────────
    var modal = document.getElementById("search-modal");
    var backdrop = document.getElementById("search-backdrop");
    var closeBtn = document.getElementById("search-close");

    var pagefindReady = false;

    function openSearch() {
        modal.removeAttribute("hidden");
        document.body.style.overflow = "hidden";

        if (!pagefindReady) {
            initPagefind();
            pagefindReady = true;
        }

        requestAnimationFrame(function () {
            var input = modal.querySelector('input[type="text"]');
            if (input) input.focus();
        });
    }

    function closeSearch() {
        modal.setAttribute("hidden", "");
        document.body.style.overflow = "";
    }

    // Expose globally so Navbar button can call it
    window.__openSearch = openSearch;

    closeBtn.addEventListener("click", closeSearch);
    backdrop.addEventListener("click", closeSearch);

    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeSearch();
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
            e.preventDefault();
            openSearch();
        }
    });
</script>

<style>
    /* ── Modal overlay ──────────────────────────────── */
    .search-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: clamp(48px, 10vh, 120px);
    }
    .search-modal[hidden] {
        display: none;
    }

    .search-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(8, 13, 26, 0.8);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        z-index: 0;
    }

    /* ── Panel ──────────────────────────────────────── */
    .search-panel {
        position: relative;
        z-index: 1; /* must be above backdrop */
        width: min(680px, calc(100vw - 32px));
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .search-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 18px 12px;
        border-bottom: 1px solid var(--color-border);
    }
    .search-panel-label {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--color-text-muted);
    }
    .search-close {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        background: none;
        border: 1px solid var(--color-border);
        border-radius: 6px;
        color: var(--color-text-muted);
        cursor: pointer;
        transition:
            color 0.15s,
            border-color 0.15s;
    }
    .search-close:hover {
        color: var(--color-text);
        border-color: var(--color-accent);
    }

    /* ── Pagefind UI overrides ──────────────────────── */
    #search-container {
        padding: 14px 16px 0;
        max-height: 60vh;
        overflow-y: auto;
        overscroll-behavior: contain;
    }

    /* Input */
    #search-container :global(.pagefind-ui__search-input) {
        width: 100%;
        background: var(--card-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 12px 16px;
        font-family: var(--font-body);
        font-size: 16px;
        color: var(--color-text);
        outline: none;
        transition: border-color 0.15s;
    }
    #search-container :global(.pagefind-ui__search-input:focus) {
        border-color: var(--color-accent);
    }
    #search-container :global(.pagefind-ui__search-input::placeholder) {
        color: var(--color-text-muted);
    }

    /* Clear button */
    #search-container :global(.pagefind-ui__search-clear) {
        background: none;
        border: none;
        color: var(--color-text-muted);
        cursor: pointer;
        font-size: 13px;
        font-family: var(--font-mono);
    }

    /* Results list */
    #search-container :global(.pagefind-ui__results) {
        margin-top: 12px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        padding-bottom: 12px;
    }

    /* Single result */
    #search-container :global(.pagefind-ui__result) {
        border: none;
        border-radius: 8px;
        padding: 0;
    }
    #search-container :global(.pagefind-ui__result-link) {
        display: block;
        padding: 12px 14px;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.15s;
    }
    #search-container :global(.pagefind-ui__result-link:hover) {
        background: rgba(232, 184, 75, 0.08);
    }
    #search-container :global(.pagefind-ui__result-title) {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: 4px;
        line-height: 1.3;
    }
    #search-container :global(.pagefind-ui__result-excerpt) {
        font-size: 13px;
        color: var(--color-text-muted);
        line-height: 1.55;
    }
    /* Highlight matched terms in gold */
    #search-container :global(.pagefind-ui__result-excerpt mark) {
        background: rgba(232, 184, 75, 0.22);
        color: var(--color-accent);
        border-radius: 2px;
        padding: 0 2px;
    }

    /* "No results" message */
    #search-container :global(.pagefind-ui__message) {
        font-size: 14px;
        color: var(--color-text-muted);
        text-align: center;
        padding: 24px 0;
        font-family: var(--font-mono);
    }

    /* ── Keyboard hint bar ──────────────────────────── */
    .search-hint {
        padding: 10px 18px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--color-text-muted);
        border-top: 1px solid var(--color-border);
        text-align: center;
        letter-spacing: 0.03em;
    }
    kbd {
        display: inline-block;
        padding: 1px 5px;
        background: var(--card-bg);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        font-size: 10px;
        font-family: var(--font-mono);
        color: var(--color-text-muted);
        margin: 0 1px;
    }
</style>
