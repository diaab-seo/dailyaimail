---
interface Props {
  article: {
    tag: string;
    headline: string;
    excerpt: string;
    date: string;
    author?: string;
    image?: string;
    href?: string;
  };
}

const { article } = Astro.props;

const tagColor = (() => {
  switch (article.tag) {
    case "Anthropic":
      return "#9D6FFF";
    case "Google AI":
      return "#4D8EF0";
    case "OpenAI":
      return "#19C99B";
    case "Meta AI":
      return "#3AABFF";
    case "Tools & Apps":
      return "#F0A030";
    case "Policy & Ethics":
      return "#F05050";
    default:
      return "#8A95A8";
  }
})();
---

<article class="hero-card">
  <figure class="hero-img-col">
    {
      article.image ? (
        <img src={article.image} alt={article.headline} class="hero-img" />
      ) : (
        <div
          class="hero-placeholder"
          style={`background: linear-gradient(135deg, ${tagColor}30, ${tagColor}0A);`}
        />
      )
    }
  </figure>
  <div class="hero-content">
    <span
      class="tag-label"
      style={`background: ${tagColor}25; color: ${tagColor}; border: 1px solid ${tagColor}40;`}
      >{article.tag}</span
    >
    <h1 class="headline">{article.headline}</h1>
    <p class="excerpt">{article.excerpt}</p>
    <footer class="meta">
      {article.author && <span class="author">By {article.author}</span>}
      <time class="date">{article.date}</time>
    </footer>
    <a href={article.href || "#"} class="read-more">Read More →</a>
  </div>
</article>

<style>
  .hero-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    min-height: 480px;
  }
  .hero-img-col {
    height: 100%;
    min-height: 400px;
    border-radius: var(--radius-card);
    overflow: hidden;
    margin: 0;
    border: 1px solid var(--color-border);
  }
  .hero-img,
  .hero-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tag-label {
    display: inline-block;
    font-size: 11px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
    padding: 5px 14px;
    border-radius: 4px;
    margin-bottom: 24px;
  }
  .headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(32px, 5vw, 42px);
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .excerpt {
    font-size: 18px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
    font-weight: 300;
  }
  .meta {
    display: flex;
    gap: 16px;
    font-size: 14px;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    margin-bottom: 32px;
  }
  .read-more {
    display: inline-block;
    background: var(--gold);
    color: #080d1a;
    padding: 14px 32px;
    border-radius: 999px;
    font-weight: 600;
    transition: opacity 0.2s;
    text-decoration: none;
    font-size: 15px;
  }
  .read-more:hover {
    opacity: 0.88;
  }

  @media (max-width: 900px) {
    .hero-card {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-img-col {
      min-height: 280px;
    }
  }
</style>
