---
interface Props {
  article: {
    tag: string;
    headline: string;
    excerpt: string;
    date: string;
    author?: string;
    image?: string;
    href?: string;
  };
}

const { article } = Astro.props;

const tagColor = (() => {
  switch(article.tag) {
    case 'Anthropic': return 'var(--tag-anthropic)';
    case 'Google AI': return 'var(--tag-google)';
    case 'OpenAI': return 'var(--tag-openai)';
    case 'Meta AI': return 'var(--tag-meta)';
    case 'Tools & Apps': return 'var(--tag-tools)';
    case 'Policy & Ethics': return 'var(--tag-policy)';
    default: return 'var(--tag-default)';
  }
})();
---

<div class="hero-card">
  <div class="hero-img-col">
    {article.image ? (
      <img src={article.image} alt={article.headline} class="hero-img" />
    ) : (
      <div class="hero-placeholder" style={`background: linear-gradient(135deg, ${tagColor}40, ${tagColor}10);`}></div>
    )}
  </div>
  <div class="hero-content">
    <span class="tag-label" style={`background: ${tagColor}`}>{article.tag}</span>
    <h1 class="headline">{article.headline}</h1>
    <p class="excerpt">{article.excerpt}</p>
    <div class="meta">
      {article.author && <span class="author">By {article.author}</span>}
      <span class="date">{article.date}</span>
    </div>
    <a href={article.href || '#'} class="read-more">Read More →</a>
  </div>
</div>

<style>
  .hero-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    min-height: 480px;
  }
  .hero-img-col {
    height: 100%;
    min-height: 400px;
    border-radius: var(--radius-card);
    overflow: hidden;
  }
  .hero-img, .hero-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tag-label {
    display: inline-block;
    color: white;
    font-size: 13px;
    text-transform: uppercase;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 4px;
    margin-bottom: 24px;
  }
  .headline {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 42px);
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--color-text);
  }
  .excerpt {
    font-size: 18px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .meta {
    display: flex;
    gap: 16px;
    font-size: 14px;
    color: var(--color-text-muted);
    margin-bottom: 32px;
  }
  .read-more {
    display: inline-block;
    background: var(--color-text);
    color: white;
    padding: 14px 32px;
    border-radius: 999px;
    font-weight: 500;
    transition: opacity 0.2s;
    text-decoration: none;
  }
  .read-more:hover {
    opacity: 0.9;
  }
  
  @media (max-width: 900px) {
    .hero-card {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-img-col {
      min-height: 280px;
    }
  }
</style>
