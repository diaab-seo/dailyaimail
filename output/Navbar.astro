      display: none;
    }
    .hamburger {
      display: flex;
    }
  }

  /* ── Search Modal ─────────────────────────── */
  /* NOTE: display is controlled entirely by JS (style.display),
     never by CSS or the [hidden] attribute, to avoid SSR/hydration conflicts */
