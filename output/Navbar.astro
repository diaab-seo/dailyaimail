</style>

<script>
  // Fetch current user state and update nav accordingly
  // Uses /api/me — short-lived private cache so it doesn't hammer the server
  (async () => {
    try {
      const res  = await fetch('/api/me');
      const user = await res.json();

      const accountItem = document.getElementById('nav-account-item');
      const accountLink = document.getElementById('nav-account-link');
      const logoutItem  = document.getElementById('nav-logout-item');

      if (!accountItem || !logoutItem) return;

      if (user && user.displayName) {
        // Logged in — show display name + sign out
        if (accountLink) {
          accountLink.textContent = user.displayName;
          accountLink.href = '/auth/register'; // link to profile page (future)
          accountLink.style.color = 'var(--gold)';
          accountLink.style.fontWeight = '600';
        }
        accountItem.style.display = '';
        logoutItem.style.display  = '';
      } else {
        // Logged out — show Sign In link only
        if (accountLink) {
          accountLink.textContent = 'Sign In';
          accountLink.href = '/auth/login';
          accountLink.style.color = '';
          accountLink.style.fontWeight = '';
        }
        accountItem.style.display = '';
        logoutItem.style.display  = 'none';
      }
    } catch {
      // Silently fail — nav still works without auth state
    }
  })();
</script>
