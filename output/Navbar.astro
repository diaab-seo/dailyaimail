<!-- Search Modal — position:fixed, JS controls display, never affects page layout -->
<div
  id="search-modal"
  class="search-modal"
  aria-modal="true"
  role="dialog"
  aria-label="Search Daily AI Mail"
>
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-container">
    <div id="search"></div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // ── Force modal hidden on init (JS-controlled, no CSS [hidden] attribute) ──
    const searchModal = document.getElementById(
      "search-modal",
    ) as HTMLElement | null;
    if (searchModal) searchModal.style.display = "none";

    // ── Hamburger ──────────────────────────────────────────────────────────────
    const hamburgerBtn = document.getElementById("hamburger-btn");
    const mainNav = document.getElementById("main-nav");

    if (hamburgerBtn && mainNav) {
      hamburgerBtn.addEventListener("click", () => {
        const isOpen = mainNav.hasAttribute("data-open");
        mainNav.toggleAttribute("data-open");
        hamburgerBtn.setAttribute("aria-expanded", String(!isOpen));
        hamburgerBtn.setAttribute(
          "aria-label",
          isOpen ? "Open menu" : "Close menu",
        );
      });
    }

    // ── Theme toggle ───────────────────────────────────────────────────────────
    function applyTheme(pref: string) {
      const root = document.documentElement;
      let resolved = pref;
      if (pref === "system") {
        resolved = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      }
      root.setAttribute("data-theme", resolved);
      root.setAttribute("data-theme-pref", pref);
      localStorage.setItem("dai-theme", pref);
      document
        .querySelectorAll<HTMLButtonElement>("[data-theme-val]")
        .forEach((btn) => {
          btn.setAttribute(
            "aria-pressed",
            String(btn.dataset.themeVal === pref),
          );
        });
    }

    const saved = localStorage.getItem("dai-theme") || "system";
    document
      .querySelectorAll<HTMLButtonElement>("[data-theme-val]")
      .forEach((btn) => {
        btn.setAttribute(
          "aria-pressed",
          String(btn.dataset.themeVal === saved),
        );
        btn.addEventListener("click", () => applyTheme(btn.dataset.themeVal!));
      });

    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        const pref = localStorage.getItem("dai-theme") || "system";
        if (pref === "system") applyTheme("system");
      });

    // ── Search modal ───────────────────────────────────────────────────────────
    const searchOpenBtn = document.getElementById("search-open-btn");
    const searchBackdrop = document.getElementById("search-backdrop");
    const searchEl = document.getElementById("search");

    if (!searchOpenBtn || !searchModal || !searchEl) return;

    let pagefindInitialised = false;

    function openSearch() {
      searchModal!.style.display = "flex";
      document.body.style.overflow = "hidden";

      if (pagefindInitialised) {
        searchModal!
          .querySelector<HTMLInputElement>("input[type=text]")
          ?.focus();
        return;
      }

      const isDev =
        window.location.hostname === "localhost" ||
        window.location.hostname === "127.0.0.1";

      if (isDev) {
        searchEl!.innerHTML = `
          <div style="padding:32px 24px;color:#8a95a8;font-size:14px;
                      font-family:var(--font-mono);text-align:center;line-height:1.9;">
            <div style="font-size:32px;margin-bottom:12px;">🔍</div>
            Search requires a production build.<br/>
            Run <code style="color:#e8b84b;background:rgba(232,184,75,0.1);
                             padding:2px 8px;border-radius:4px;">
              npm run build &amp;&amp; npm run preview
            </code><br/>to test search locally.
          </div>`;
        pagefindInitialised = true;
        return;
      }

      // Production — lazy-load pagefind
      const pagefindPath = ["", "pagefind", "pagefind-ui.js"].join("/");
      // @ts-ignore
      import(/* @vite-ignore */ pagefindPath)
        .then(({ PagefindUI }) => {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            showImages: false,
            resetStyles: false,
          });
          pagefindInitialised = true;
          setTimeout(() => {
            searchModal!
              .querySelector<HTMLInputElement>("input[type=text]")
              ?.focus();
          }, 50);
        })
        .catch((e: unknown) => {
          console.warn("[Search] Pagefind failed to load:", e);
          searchEl!.innerHTML = `
          <div style="padding:24px;color:#8a95a8;text-align:center;
                      font-family:var(--font-mono);font-size:14px;">
            Search index not available.
          </div>`;
        });
    }

    function closeSearch() {
      searchModal!.style.display = "none";
      document.body.style.overflow = "";
    }

    searchOpenBtn.addEventListener("click", openSearch);
    searchBackdrop?.addEventListener("click", closeSearch);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeSearch();
      if (e.key === "k" && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        openSearch();
      }
    });
  });
</script>

<style>
  /* ── Navbar shell ─────────────────────────── */
  .navbar {
    background: var(--nav-bg);
    color: var(--nav-text);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(232, 184, 75, 0.1);
  }
  .navbar-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* ── Logo ─────────────────────────────────── */
  .navbar-logo {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 900;
    text-decoration: none;
    color: var(--nav-text);
    flex-shrink: 0;
    letter-spacing: -0.01em;
  }
  .navbar-logo em {
    font-style: italic;
    color: #e8b84b;
  }

  /* ── Desktop nav links ───────────────────── */
  .desktop-nav {
    display: flex;
    list-style: none;
    gap: 4px;
    margin: 0;
    padding: 0;
    flex: 1;
    justify-content: center;
  }
  .desktop-nav > li {
    position: relative;
  }
  .desktop-nav > li > a {
    display: block;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 6px;
    color: rgba(244, 240, 232, 0.75);
    transition:
      color 0.15s,
      background 0.15s;
    white-space: nowrap;
  }
  .desktop-nav > li > a:hover {
    color: #f4f0e8;
    background: rgba(255, 255, 255, 0.07);
  }

  /* ── Dropdown ─────────────────────────────── */
  .has-dropdown .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: #111828;
    border: 1px solid rgba(232, 184, 75, 0.15);
    padding: 6px;
    border-radius: 8px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
    list-style: none;
    min-width: 188px;
    z-index: 200;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: block;
  }
  .nav-divider { height:1px; background:var(--color-border); margin:4px 8px; }
  .nav-logout-btn { background:none; border:none; padding:0; font-size:inherit; font-family:inherit; color:inherit; cursor:pointer; width:100%; text-align:left; }
  .nav-logout-btn:hover { color:var(--gold); }
  .dropdown li a {
    display: block;
    font-size: 13.5px;
    padding: 9px 14px;
    border-radius: 5px;
    color: rgba(244, 240, 232, 0.75);
    transition:
      background 0.15s,
      color 0.15s;
  }
  .dropdown li a:hover {
    background: rgba(232, 184, 75, 0.09);
    color: #e8b84b;
  }

  /* ── Nav actions ─────────────────────────── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* ── Icon buttons ────────────────────────── */
  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid rgba(244, 240, 232, 0.12);
    border-radius: 8px;
    color: rgba(244, 240, 232, 0.7);
    cursor: pointer;
    transition:
      color 0.15s,
      border-color 0.15s,
      background 0.15s;
  }
  .icon-btn:hover {
    color: #f4f0e8;
    border-color: rgba(232, 184, 75, 0.4);
    background: rgba(232, 184, 75, 0.07);
  }

  /* ── Theme toggle ─────────────────────────── */
  .theme-toggle {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(244, 240, 232, 0.1);
    border-radius: 8px;
    padding: 3px;
    gap: 1px;
  }
  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 30px;
    height: 28px;
    background: none;
    border: none;
    border-radius: 5px;
    color: rgba(244, 240, 232, 0.45);
    cursor: pointer;
    transition:
      color 0.15s,
      background 0.15s;
    padding: 0 6px;
  }
  .theme-btn:hover {
    color: rgba(244, 240, 232, 0.85);
    background: rgba(255, 255, 255, 0.06);
  }
  .theme-btn[aria-pressed="true"] {
    background: rgba(232, 184, 75, 0.15);
    color: #e8b84b;
  }

  /* ── Hide on mobile ──────────────────────── */
  @media (max-width: 900px) {
    .hide-mobile {
      display: none !important;
    }
  }

  /* ── Hamburger ───────────────────────────── */
  .hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid rgba(244, 240, 232, 0.12);
    border-radius: 8px;
    color: rgba(244, 240, 232, 0.8);
    cursor: pointer;
    transition:
      color 0.15s,
      border-color 0.15s;
  }
  .hamburger:hover {
    color: #f4f0e8;
    border-color: rgba(232, 184, 75, 0.4);
  }

  /* ── Mobile nav ───────────────────────────── */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px var(--gutter) 16px;
    margin: 0;
    list-style: none;
    background: #0a1020;
    border-top: 1px solid rgba(232, 184, 75, 0.1);
  }
  .mobile-nav li a {
    display: block;
    padding: 13px 0;
    font-size: 15px;
    font-weight: 500;
    color: rgba(244, 240, 232, 0.75);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: color 0.15s;
  }
  .mobile-nav li a:hover {
    color: #e8b84b;
  }
  .mobile-theme-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0 4px;
  }
  .mobile-theme-label {
    font-size: 12px;
    font-family: var(--font-mono);
    color: rgba(244, 240, 232, 0.4);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .theme-toggle--mobile {
    background: rgba(255, 255, 255, 0.05);
  }
  .theme-toggle--mobile .theme-btn {
    width: auto;
    padding: 0 10px;
    height: 30px;
    font-size: 12px;
    font-family: var(--font-mono);
    gap: 6px;
  }
  .theme-toggle--mobile .theme-btn span {
    letter-spacing: 0.04em;
    font-size: 11px;
  }

  /* ── Open state ───────────────────────────── */
  nav[data-open] .mobile-nav {
    display: flex;
  }
  nav[data-open] .hamburger {
    color: #e8b84b;
    border-color: rgba(232, 184, 75, 0.4);
  }

  /* ── Responsive breakpoints ──────────────── */
  @media (max-width: 1100px) {
